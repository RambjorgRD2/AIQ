---
export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Sosial AI Forum — live events, peer learning, and structured AI upskilling for practitioners at every level. Discover your AIQ. Powered by Optimal AI.',
} = Astro.props;

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Auth nav strip — top-right on desktop, bottom-right on mobile -->
    <div id="auth-nav" class="auth-nav">
      <!-- Shown when NOT signed in -->
      <a href={`${BASE}/signin`} data-auth-hide class="auth-signin-link">Sign In</a>

      <!-- Shown when signed in — dropdown trigger -->
      <div data-auth-show id="auth-dropdown-wrap" style="display:none; position:relative;">
        <button id="auth-dropdown-btn" class="auth-dropdown-btn" aria-haspopup="true" aria-expanded="false">
          <span id="auth-tier-badge" class="auth-tier-chip"></span>
          <span class="auth-user-email auth-user-email-short" id="auth-user-email"></span>
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" id="auth-chevron"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        <div id="auth-dropdown-panel" class="auth-dropdown-panel" hidden>
          <!-- My AIQ section -->
          <div class="auth-dd-section">
            <div class="auth-dd-label">My AIQ</div>
            <a href={`${BASE}/results`} class="auth-dd-aiq auth-dd-link" id="auth-aiq-display">
              <span id="auth-aiq-score" class="auth-aiq-score">—</span>
              <span id="auth-aiq-tier" class="auth-aiq-tier"></span>
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none" style="margin-left:auto;opacity:0.4;flex-shrink:0"><path d="M2 8L8 2M8 2H4M8 2v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="auth-dd-divider"></div>
          <!-- Course progress section -->
          <div class="auth-dd-section">
            <div class="auth-dd-label">Course Progress</div>
            <div class="auth-dd-progress-list">
              <a href={`${BASE}/courses/foundations`} class="auth-dd-progress-row auth-dd-link">
                <span class="auth-dd-course-name">AI~Foundations</span>
                <span id="prog-foundations" class="auth-dd-fraction">0/12</span>
              </a>
              <a href={`${BASE}/courses/workflows`} class="auth-dd-progress-row auth-dd-link">
                <span class="auth-dd-course-name">AI~Workflows</span>
                <span id="prog-workflows" class="auth-dd-fraction">0/22</span>
              </a>
              <a href={`${BASE}/courses/leadership`} class="auth-dd-progress-row auth-dd-link">
                <span class="auth-dd-course-name">AI~Leadership</span>
                <span id="prog-leadership" class="auth-dd-fraction">0/21</span>
              </a>
            </div>
          </div>
          <div class="auth-dd-divider"></div>
          <!-- Sign out -->
          <button data-sign-out class="auth-dd-signout">Sign Out</button>
        </div>
      </div>
    </div>

    <!-- Undo toast — appears after clicking Sign Out -->
    <div id="auth-toast" class="auth-toast" role="status" aria-live="polite">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink:0"><path d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8z" fill="var(--muted)"/><path d="M8 4.5a.75.75 0 0 1 .75.75v3.5l2.25 1.3a.75.75 0 1 1-.75 1.3L7.5 9.9a.75.75 0 0 1-.375-.65V5.25A.75.75 0 0 1 8 4.5z" fill="var(--muted)"/></svg>
      <span>Signed out</span>
      <button id="auth-toast-undo" class="auth-toast-undo">Undo</button>
      <span id="auth-toast-timer" class="auth-toast-timer">5</span>
    </div>

    <slot />

    <script>
      import { supabase } from '../lib/supabase.ts'
      import { upsertLessonProgress, upsertAssessmentResult, upsertReflectionNote, getLatestAssessmentResult, getCompletedLessons } from '../lib/db.ts'

      // Migrate existing localStorage data to Supabase on sign-in
      async function migrateLocalStorageToSupabase(userId: string) {
        // Migrate lesson completions
        const courseMap = [
          { key: 'aiq-foundations-completed', courseId: 'foundations' },
          { key: 'aiq-workflows-completed', courseId: 'workflows' },
          { key: 'aiq-leadership-completed', courseId: 'leadership' },
        ];
        for (const { key, courseId } of courseMap) {
          const ids: string[] = JSON.parse(localStorage.getItem(key) || '[]');
          for (const lessonId of ids) {
            await upsertLessonProgress({ userId, lessonId, courseId }).catch(console.error);
          }
        }

        // Migrate reflection notes — scan all localStorage keys
        const prefixes = [
          { prefix: 'reflection-' },
          { prefix: 'wf-reflection-' },
          { prefix: 'ld-reflection-' },
        ];
        for (let i = 0; i < localStorage.length; i++) {
          const k = localStorage.key(i);
          if (!k) continue;
          for (const { prefix } of prefixes) {
            if (k.startsWith(prefix)) {
              const lessonId = k.slice(prefix.length);
              const noteText = localStorage.getItem(k) || '';
              if (noteText) {
                await upsertReflectionNote({ userId, lessonId, noteText }).catch(console.error);
              }
            }
          }
        }

        // Migrate latest assessment result
        const raw = localStorage.getItem('aiq_latest_result');
        if (raw) {
          try {
            const r = JSON.parse(raw);
            await upsertAssessmentResult({
              userId,
              score: r.scores?.aiq ?? r.score ?? 0,
              tier: String(r.tier?.tier ?? r.tier ?? ''),
              tierLabel: r.tier?.label ?? r.tierLabel ?? r.tier_label ?? '',
              radarData: r.scores ?? r.radarData ?? r.radar_data,
            }).catch(console.error);
          } catch (_e) { /* malformed JSON, skip */ }
        }
      }

      // Subscribe to auth state changes — fires on page load and on sign in/out
      supabase.auth.onAuthStateChange((_event, session) => {
        const user = session?.user ?? null

        // Toggle auth UI elements
        document.querySelectorAll('[data-auth-show]').forEach(el => {
          ;(el as HTMLElement).style.display = user
            ? (el.id === 'auth-dropdown-wrap' ? 'flex' : '')
            : 'none'
        })
        document.querySelectorAll('[data-auth-hide]').forEach(el => {
          ;(el as HTMLElement).style.display = user ? 'none' : ''
        })

        if (user) {
          // Show truncated email
          const emailShort = (user.email ?? '').slice(0, 18)
          document.querySelectorAll('.auth-user-email').forEach(el => {
            ;(el as HTMLElement).textContent = emailShort
          })

          // Populate dropdown data
          getLatestAssessmentResult(user.id).then(result => {
            if (result) {
              const scoreEl = document.getElementById('auth-aiq-score')
              const tierEl = document.getElementById('auth-aiq-tier')
              const badgeEl = document.getElementById('auth-tier-badge')
              if (scoreEl) scoreEl.textContent = String(result.score)
              if (tierEl) tierEl.textContent = result.tier_label || result.tier
              if (badgeEl) {
                badgeEl.textContent = result.tier ? `L${result.tier}` : ''
                badgeEl.style.display = result.tier ? '' : 'none'
              }
            }
          }).catch(() => {})

          getCompletedLessons(user.id, 'foundations').then(ids => {
            const el = document.getElementById('prog-foundations')
            if (el) el.textContent = `${ids.length}/12`
          }).catch(() => {})

          getCompletedLessons(user.id, 'workflows').then(ids => {
            const el = document.getElementById('prog-workflows')
            if (el) el.textContent = `${ids.length}/22`
          }).catch(() => {})

          getCompletedLessons(user.id, 'leadership').then(ids => {
            const el = document.getElementById('prog-leadership')
            if (el) el.textContent = `${ids.length}/21`
          }).catch(() => {})
        } else {
          // Reset dropdown values on sign-out
          const scoreEl = document.getElementById('auth-aiq-score')
          const tierEl = document.getElementById('auth-aiq-tier')
          const badgeEl = document.getElementById('auth-tier-badge')
          if (scoreEl) scoreEl.textContent = '—'
          if (tierEl) tierEl.textContent = ''
          if (badgeEl) { badgeEl.textContent = ''; badgeEl.style.display = 'none' }
          const progEls = [
            { id: 'prog-foundations', def: '0/12' },
            { id: 'prog-workflows', def: '0/22' },
            { id: 'prog-leadership', def: '0/21' },
          ]
          progEls.forEach(({ id, def }) => {
            const el = document.getElementById(id)
            if (el) el.textContent = def
          })
        }

        // Expose user globally for page-level scripts
        ;(window as any).__supabaseUser = user

        // On sign-in: migrate any existing localStorage data to Supabase
        if (_event === 'SIGNED_IN' && user) {
          migrateLocalStorageToSupabase(user.id);
        }
      })

      // ── Dropdown toggle ──────────────────────────────────
      const dropBtn = document.getElementById('auth-dropdown-btn')
      const dropPanel = document.getElementById('auth-dropdown-panel')
      const chevron = document.getElementById('auth-chevron')
      dropBtn?.addEventListener('click', () => {
        const isOpen = dropPanel?.hasAttribute('hidden') === false
        if (isOpen) {
          dropPanel?.setAttribute('hidden', '')
          dropBtn.setAttribute('aria-expanded', 'false')
          if (chevron) chevron.style.transform = ''
        } else {
          dropPanel?.removeAttribute('hidden')
          dropBtn.setAttribute('aria-expanded', 'true')
          if (chevron) chevron.style.transform = 'rotate(180deg)'
        }
      })
      // Close on outside click
      document.addEventListener('click', (e) => {
        const wrap = document.getElementById('auth-dropdown-wrap')
        if (wrap && !wrap.contains(e.target as Node)) {
          dropPanel?.setAttribute('hidden', '')
          dropBtn?.setAttribute('aria-expanded', 'false')
          if (chevron) chevron.style.transform = ''
        }
      })

      // ── Undo-toast sign-out ──────────────────────────────
      const TOAST_DURATION = 5000

      function showSignOutToast() {
        const toast = document.getElementById('auth-toast')!
        const undoBtn = document.getElementById('auth-toast-undo')!
        const timerEl = document.getElementById('auth-toast-timer')!

        let remaining = Math.round(TOAST_DURATION / 1000)
        timerEl.textContent = String(remaining)
        toast.classList.add('visible')

        // Countdown tick
        const tick = setInterval(() => {
          remaining--
          timerEl.textContent = String(remaining)
          if (remaining <= 0) clearInterval(tick)
        }, 1000)

        // Sign out after delay
        const signOutTimer = setTimeout(async () => {
          clearInterval(tick)
          toast.classList.remove('visible')
          await supabase.auth.signOut()
          window.location.href = '/'
        }, TOAST_DURATION)

        // Undo: cancel timer, hide toast — session stays active
        undoBtn.onclick = () => {
          clearTimeout(signOutTimer)
          clearInterval(tick)
          toast.classList.remove('visible')
        }
      }

      document.querySelectorAll('[data-sign-out]').forEach(btn => {
        btn.addEventListener('click', showSignOutToast)
      })
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #04070f;
    --surface: #080d1a;
    --card: rgba(10, 18, 40, 0.75);
    --cyan: #00cfff;
    --violet: #7c3aed;
    --text: #e8f0ff;
    --muted: #6b7a99;
    --border: rgba(0, 207, 255, 0.1);
    --border-hover: rgba(0, 207, 255, 0.3);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
    line-height: 1.6;
  }

  h1,
  h2,
  h3,
  h4,
  h5 {
    font-family: 'Space Grotesk', sans-serif;
    line-height: 1.15;
  }

  /* Gradient text */
  .gradient-text {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--violet) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .gradient-text-warm {
    background: linear-gradient(135deg, #00cfff 0%, #a855f7 50%, #ec4899 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Grid background */
  .grid-bg {
    background-image:
      linear-gradient(rgba(0, 207, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 207, 255, 0.03) 1px, transparent 1px);
    background-size: 56px 56px;
  }

  /* Glassmorphism */
  .glass {
    background: var(--card);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: 16px;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .glass:hover {
    border-color: var(--border-hover);
    box-shadow: 0 0 30px rgba(0, 207, 255, 0.08);
  }

  /* Glow blobs */
  .glow-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    opacity: 0.25;
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(36px);
    transition:
      opacity 0.75s ease,
      transform 0.75s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }
  .reveal-delay-5 { transition-delay: 0.5s; }

  /* Section spacing */
  section {
    position: relative;
    padding: 6rem 1.5rem;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
    width: 100%;
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: linear-gradient(135deg, var(--cyan), var(--violet));
    color: #fff;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease, box-shadow 0.3s ease;
    box-shadow: 0 0 20px rgba(0, 207, 255, 0.2);
  }

  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    box-shadow: 0 0 36px rgba(0, 207, 255, 0.35);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: transparent;
    color: var(--text);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 999px;
    border: 1px solid var(--border-hover);
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .btn-secondary:hover {
    background: rgba(0, 207, 255, 0.06);
    border-color: var(--cyan);
    transform: translateY(-1px);
  }

  /* Label chip */
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 1rem;
    background: rgba(0, 207, 255, 0.08);
    border: 1px solid rgba(0, 207, 255, 0.2);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 1.25rem;
  }

  /* Section title */
  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .section-sub {
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 560px;
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg);
  }
  ::-webkit-scrollbar-thumb {
    background: rgba(0, 207, 255, 0.25);
    border-radius: 3px;
  }

  /* ── Auth nav strip ───────────────────────────────────── */
  .auth-nav {
    position: fixed;
    top: 0;
    right: 0;
    z-index: 9000;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
  }

  .auth-signin-link,
  .auth-signout-btn {
    color: var(--cyan);
    text-decoration: none;
    padding: 0.4rem 1rem;
    border: 1px solid var(--border-hover);
    border-radius: 999px;
    transition: background 0.2s, border-color 0.2s;
    cursor: pointer;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    background: none;
  }

  .auth-signin-link:hover,
  .auth-signout-btn:hover {
    background: rgba(0, 207, 255, 0.08);
    border-color: var(--cyan);
  }

  .auth-email {
    color: var(--muted);
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── Auth dropdown ─────────────────────────────────────── */
  .auth-dropdown-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    background: none;
    border: 1px solid transparent;
    border-radius: 999px;
    cursor: pointer;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.82rem;
    color: var(--text);
    transition: border-color 0.2s, background 0.2s;
  }

  .auth-dropdown-btn:hover {
    border-color: rgba(0, 207, 255, 0.3);
    background: rgba(0, 207, 255, 0.04);
  }

  #auth-chevron {
    color: var(--muted);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .auth-tier-chip {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--cyan);
    border: 1px solid rgba(0, 207, 255, 0.35);
    border-radius: 4px;
    padding: 0.1rem 0.35rem;
    line-height: 1.4;
  }

  .auth-user-email-short {
    color: var(--muted);
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .auth-dropdown-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 8px);
    min-width: 220px;
    background: rgba(4, 7, 15, 0.97);
    border: 1px solid rgba(0, 207, 255, 0.15);
    border-radius: 12px;
    padding: 1rem;
    z-index: 200;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  }

  .auth-dd-section {
    /* spacing handled by children */
  }

  .auth-dd-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 0.5rem;
    font-family: 'Space Grotesk', sans-serif;
  }

  .auth-dd-aiq {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .auth-aiq-score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--cyan);
  }

  .auth-aiq-tier {
    font-size: 0.8rem;
    color: var(--muted);
    font-family: 'Space Grotesk', sans-serif;
  }

  .auth-dd-divider {
    height: 1px;
    background: rgba(0, 207, 255, 0.08);
    margin: 0.75rem 0;
  }

  .auth-dd-progress-list {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .auth-dd-link {
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.15s;
    margin: 0 -0.4rem;
    padding-left: 0.4rem;
    padding-right: 0.4rem;
  }

  .auth-dd-link:hover {
    background: rgba(0, 207, 255, 0.06);
  }

  .auth-dd-aiq.auth-dd-link {
    align-items: center;
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
  }

  .auth-dd-progress-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.25rem 0.4rem;
    margin: 0 -0.4rem;
  }

  .auth-dd-course-name {
    font-size: 0.82rem;
    font-family: 'Space Grotesk', sans-serif;
    color: var(--text);
  }

  .auth-dd-fraction {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .auth-dd-signout {
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    color: var(--muted);
    padding: 0.2rem 0;
    transition: color 0.2s;
  }

  .auth-dd-signout:hover {
    color: var(--cyan);
  }

  /* Mobile: auth lives in the hamburger menu on all pages */
  @media (max-width: 768px) {
    .auth-nav {
      display: none;
    }
  }

  /* ── Undo toast ───────────────────────────────────────── */
  .auth-toast {
    position: fixed;
    bottom: 1.75rem;
    left: 50%;
    transform: translateX(-50%) translateY(calc(100% + 2rem));
    opacity: 0;
    pointer-events: none;
    background: var(--card);
    border: 1px solid var(--border-hover);
    border-radius: 999px;
    padding: 0.6rem 0.75rem 0.6rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    color: var(--text);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
