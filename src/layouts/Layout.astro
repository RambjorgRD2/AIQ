---
export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Sosial AI Forum — live events, peer learning, and structured AI upskilling for practitioners at every level. Discover your AIQ. Powered by Optimal AI.',
} = Astro.props;

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Auth nav strip — top-right on desktop, bottom-right on mobile -->
    <div id="auth-nav" class="auth-nav">
      <!-- Shown when NOT signed in -->
      <a href={`${BASE}/signin`} data-auth-hide class="auth-signin-link">Sign In</a>
      <!-- Shown when signed in -->
      <span data-auth-show class="auth-email auth-user-email" id="auth-user-email" style="display:none"></span>
      <button data-auth-show data-sign-out class="auth-signout-btn" style="display:none">Sign Out</button>
    </div>

    <!-- Undo toast — appears after clicking Sign Out -->
    <div id="auth-toast" class="auth-toast" role="status" aria-live="polite">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink:0"><path d="M8 1.5a6.5 6.5 0 1 0 0 13 6.5 6.5 0 0 0 0-13zM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8z" fill="var(--muted)"/><path d="M8 4.5a.75.75 0 0 1 .75.75v3.5l2.25 1.3a.75.75 0 1 1-.75 1.3L7.5 9.9a.75.75 0 0 1-.375-.65V5.25A.75.75 0 0 1 8 4.5z" fill="var(--muted)"/></svg>
      <span>Signed out</span>
      <button id="auth-toast-undo" class="auth-toast-undo">Undo</button>
      <span id="auth-toast-timer" class="auth-toast-timer">5</span>
    </div>

    <slot />

    <script>
      import { supabase } from '../lib/supabase.ts'
      import { upsertLessonProgress, upsertAssessmentResult, upsertReflectionNote } from '../lib/db.ts'

      // Migrate existing localStorage data to Supabase on sign-in
      async function migrateLocalStorageToSupabase(userId: string) {
        // Migrate lesson completions
        const courseMap = [
          { key: 'aiq-foundations-completed', courseId: 'foundations' },
          { key: 'aiq-workflows-completed', courseId: 'workflows' },
          { key: 'aiq-leadership-completed', courseId: 'leadership' },
        ];
        for (const { key, courseId } of courseMap) {
          const ids: string[] = JSON.parse(localStorage.getItem(key) || '[]');
          for (const lessonId of ids) {
            await upsertLessonProgress({ userId, lessonId, courseId }).catch(console.error);
          }
        }

        // Migrate reflection notes — scan all localStorage keys
        const prefixes = [
          { prefix: 'reflection-' },
          { prefix: 'wf-reflection-' },
          { prefix: 'ld-reflection-' },
        ];
        for (let i = 0; i < localStorage.length; i++) {
          const k = localStorage.key(i);
          if (!k) continue;
          for (const { prefix } of prefixes) {
            if (k.startsWith(prefix)) {
              const lessonId = k.slice(prefix.length);
              const noteText = localStorage.getItem(k) || '';
              if (noteText) {
                await upsertReflectionNote({ userId, lessonId, noteText }).catch(console.error);
              }
            }
          }
        }

        // Migrate latest assessment result
        const raw = localStorage.getItem('aiq_latest_result');
        if (raw) {
          try {
            const r = JSON.parse(raw);
            await upsertAssessmentResult({
              userId,
              score: r.scores?.aiq ?? r.score ?? 0,
              tier: String(r.tier?.tier ?? r.tier ?? ''),
              tierLabel: r.tier?.label ?? r.tierLabel ?? r.tier_label ?? '',
              radarData: r.scores ?? r.radarData ?? r.radar_data,
            }).catch(console.error);
          } catch (_e) { /* malformed JSON, skip */ }
        }
      }

      // Subscribe to auth state changes — fires on page load and on sign in/out
      supabase.auth.onAuthStateChange((_event, session) => {
        const user = session?.user ?? null

        // Toggle auth UI elements
        document.querySelectorAll('[data-auth-show]').forEach(el => {
          ;(el as HTMLElement).style.display = user ? '' : 'none'
        })
        document.querySelectorAll('[data-auth-hide]').forEach(el => {
          ;(el as HTMLElement).style.display = user ? 'none' : ''
        })

        // Show user email in all auth-user-email elements (desktop strip + mobile menu)
        document.querySelectorAll('.auth-user-email').forEach(el => {
          if (user) (el as HTMLElement).textContent = user.email ?? ''
        })

        // Expose user globally for page-level scripts
        ;(window as any).__supabaseUser = user

        // On sign-in: migrate any existing localStorage data to Supabase
        if (_event === 'SIGNED_IN' && user) {
          migrateLocalStorageToSupabase(user.id);
        }
      })

      // ── Undo-toast sign-out ──────────────────────────────
      const TOAST_DURATION = 5000

      function showSignOutToast() {
        const toast = document.getElementById('auth-toast')!
        const undoBtn = document.getElementById('auth-toast-undo')!
        const timerEl = document.getElementById('auth-toast-timer')!

        let remaining = Math.round(TOAST_DURATION / 1000)
        timerEl.textContent = String(remaining)
        toast.classList.add('visible')

        // Countdown tick
        const tick = setInterval(() => {
          remaining--
          timerEl.textContent = String(remaining)
          if (remaining <= 0) clearInterval(tick)
        }, 1000)

        // Sign out after delay
        const signOutTimer = setTimeout(async () => {
          clearInterval(tick)
          toast.classList.remove('visible')
          await supabase.auth.signOut()
          window.location.href = '/'
        }, TOAST_DURATION)

        // Undo: cancel timer, hide toast — session stays active
        undoBtn.onclick = () => {
          clearTimeout(signOutTimer)
          clearInterval(tick)
          toast.classList.remove('visible')
        }
      }

      document.querySelectorAll('[data-sign-out]').forEach(btn => {
        btn.addEventListener('click', showSignOutToast)
      })
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #04070f;
    --surface: #080d1a;
    --card: rgba(10, 18, 40, 0.75);
    --cyan: #00cfff;
    --violet: #7c3aed;
    --text: #e8f0ff;
    --muted: #6b7a99;
    --border: rgba(0, 207, 255, 0.1);
    --border-hover: rgba(0, 207, 255, 0.3);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-color: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
    line-height: 1.6;
  }

  h1,
  h2,
  h3,
  h4,
  h5 {
    font-family: 'Space Grotesk', sans-serif;
    line-height: 1.15;
  }

  /* Gradient text */
  .gradient-text {
    background: linear-gradient(135deg, var(--cyan) 0%, var(--violet) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .gradient-text-warm {
    background: linear-gradient(135deg, #00cfff 0%, #a855f7 50%, #ec4899 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Grid background */
  .grid-bg {
    background-image:
      linear-gradient(rgba(0, 207, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 207, 255, 0.03) 1px, transparent 1px);
    background-size: 56px 56px;
  }

  /* Glassmorphism */
  .glass {
    background: var(--card);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: 16px;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .glass:hover {
    border-color: var(--border-hover);
    box-shadow: 0 0 30px rgba(0, 207, 255, 0.08);
  }

  /* Glow blobs */
  .glow-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    opacity: 0.25;
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(36px);
    transition:
      opacity 0.75s ease,
      transform 0.75s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }
  .reveal-delay-5 { transition-delay: 0.5s; }

  /* Section spacing */
  section {
    position: relative;
    padding: 6rem 1.5rem;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
    width: 100%;
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: linear-gradient(135deg, var(--cyan), var(--violet));
    color: #fff;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease, box-shadow 0.3s ease;
    box-shadow: 0 0 20px rgba(0, 207, 255, 0.2);
  }

  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
    box-shadow: 0 0 36px rgba(0, 207, 255, 0.35);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: transparent;
    color: var(--text);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 999px;
    border: 1px solid var(--border-hover);
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .btn-secondary:hover {
    background: rgba(0, 207, 255, 0.06);
    border-color: var(--cyan);
    transform: translateY(-1px);
  }

  /* Label chip */
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 1rem;
    background: rgba(0, 207, 255, 0.08);
    border: 1px solid rgba(0, 207, 255, 0.2);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 1.25rem;
  }

  /* Section title */
  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
  }

  .section-sub {
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 560px;
  }

  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg);
  }
  ::-webkit-scrollbar-thumb {
    background: rgba(0, 207, 255, 0.25);
    border-radius: 3px;
  }

  /* ── Auth nav strip ───────────────────────────────────── */
  .auth-nav {
    position: fixed;
    top: 0;
    right: 0;
    z-index: 9000;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
  }

  .auth-signin-link,
  .auth-signout-btn {
    color: var(--cyan);
    text-decoration: none;
    padding: 0.4rem 1rem;
    border: 1px solid var(--border-hover);
    border-radius: 999px;
    transition: background 0.2s, border-color 0.2s;
    cursor: pointer;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    background: none;
  }

  .auth-signin-link:hover,
  .auth-signout-btn:hover {
    background: rgba(0, 207, 255, 0.08);
    border-color: var(--cyan);
  }

  .auth-email {
    color: var(--muted);
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Mobile: auth lives in the hamburger menu on all pages */
  @media (max-width: 768px) {
    .auth-nav {
      display: none;
    }
  }

  /* ── Undo toast ───────────────────────────────────────── */
  .auth-toast {
    position: fixed;
    bottom: 1.75rem;
    left: 50%;
    transform: translateX(-50%) translateY(calc(100% + 2rem));
    opacity: 0;
    pointer-events: none;
    background: var(--card);
    border: 1px solid var(--border-hover);
    border-radius: 999px;
    padding: 0.6rem 0.75rem 0.6rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    color: var(--text);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    z-index: 10000;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    white-space: nowrap;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .auth-toast.visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .auth-toast-undo {
    color: var(--cyan);
    background: rgba(0, 207, 255, 0.1);
    border: 1px solid rgba(0, 207, 255, 0.25);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .auth-toast-undo:hover {
    background: rgba(0, 207, 255, 0.18);
    border-color: var(--cyan);
  }

  .auth-toast-timer {
    color: var(--muted);
    font-size: 0.75rem;
    min-width: 1ch;
    text-align: center;
  }

  /* On mobile: toast sits above the auth pill */
  @media (max-width: 768px) {
    .auth-toast {
      bottom: 4.5rem;
    }
  }
</style>
