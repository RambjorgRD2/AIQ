     c:2},
    {id:'E2', sl:'ETHICS & CRITICAL THINKING', d:{t:0.5,l:0.5},
     q:'A colleague uses AI to generate a research report and presents it as their own original analysis to a client. What\'s the primary concern?',
     ctx:null,
     opts:['The AI may have made factual errors in the report',
