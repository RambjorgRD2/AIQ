---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="AIQ Assessment — Discover Your AI Quotient"
  description="22 questions. ~8 minutes. Find out how effectively you think, work, and lead with AI."
>

<!-- NAV -->
<nav class="a-nav">
  <div class="a-nav-inner">
    <a href={`${import.meta.env.BASE_URL}`} class="a-nav-logo" aria-label="AIQ Home">
      <svg width="60" height="24" viewBox="0 0 72 28" fill="none">
        <text x="0" y="22" font-family="'Space Grotesk',sans-serif" font-size="22" font-weight="800" fill="url(#g1)">AIQ</text>
        <path d="M2 26 Q18 21 36 26 Q54 21 70 26" stroke="url(#g1)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
        <defs>
          <linearGradient id="g1" x1="0" y1="0" x2="72" y2="0" gradientUnits="userSpaceOnUse">
            <stop stop-color="#00CFFF"/><stop offset="1" stop-color="#7C3AED"/>
          </linearGradient>
        </defs>
      </svg>
    </a>
    <span id="nav-progress" class="a-nav-prog"></span>
  </div>
</nav>

<!-- ── STAGES ────────────────────────────────────────── -->
<div id="aiq-app">

  <!-- STAGE 1: WELCOME -->
  <div id="s-welcome" class="stage">
    <div class="stage-body center-body">
      <div class="chip" style="margin-bottom:1.5rem">AI~Quotient Assessment</div>
      <h1 class="welcome-h1">Know Your <span class="gradient-text">AIQ.</span></h1>
      <p class="welcome-sub">Discover how effectively you think, work, and lead with AI — in under 10 minutes.</p>

      <div class="welcome-meta">
        <span>22 questions</span>
        <span class="sep">·</span>
        <span>~8 minutes</span>
        <span class="sep">·</span>
        <span>9 tiers</span>
      </div>

      <div class="dims-row">
        <div class="dim-badge dim-think">
          <span class="dim-name">THINK</span>
          <span class="dim-pct">35%</span>
        </div>
        <div class="dim-badge dim-apply">
          <span class="dim-name">APPLY</span>
          <span class="dim-pct">45%</span>
        </div>
        <div class="dim-badge dim-lead">
          <span class="dim-name">LEAD</span>
          <span class="dim-pct">20%</span>
        </div>
      </div>

      <button id="btn-start" class="btn-primary btn-lg">
        Start Assessment
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>

      <p class="fine-print">Free · No account required · Results saved locally</p>
    </div>
  </div>

  <!-- STAGE 2: CONTEXTUALISE -->
  <div id="s-context" class="stage" style="display:none">
    <div class="stage-body stage-narrow">
      <div class="chip" style="margin-bottom:1rem">Step 1 of 2 — About You</div>
      <h2 class="stage-h2">Personalise your results</h2>
      <p class="stage-sub">Takes 30 seconds. Drives adaptive question routing and personalised insights.</p>

      <div class="ctx-group" data-group="role">
        <div class="ctx-label">Your Role</div>
        <div class="ctx-chips">
          <button class="ctx-chip" data-value="individual">Individual Contributor</button>
          <button class="ctx-chip" data-value="manager">Manager</button>
          <button class="ctx-chip" data-value="executive">Executive</button>
          <button class="ctx-chip" data-value="student">Student / Learning</button>
        </div>
      </div>

      <div class="ctx-group" data-group="domain">
        <div class="ctx-label">Your Domain</div>
        <div class="ctx-chips">
          <button class="ctx-chip" data-value="business">Business</button>
          <button class="ctx-chip" data-value="creative">Creative</button>
          <button class="ctx-chip" data-value="technical">Technical</button>
          <button class="ctx-chip" data-value="education">Education</button>
          <button class="ctx-chip" data-value="healthcare">Healthcare</button>
          <button class="ctx-chip" data-value="other">Other</button>
        </div>
      </div>

      <div class="ctx-group" data-group="experience">
        <div class="ctx-label">AI Experience</div>
        <div class="ctx-chips">
          <button class="ctx-chip" data-value="never">Never used AI tools</button>
          <button class="ctx-chip" data-value="occasional">Occasional use</button>
          <button class="ctx-chip" data-value="regular">Use AI regularly</button>
          <button class="ctx-chip" data-value="build">Build with AI</button>
        </div>
      </div>

      <div class="ctx-group" data-group="goal">
        <div class="ctx-label">Primary Goal</div>
        <div class="ctx-chips">
          <button class="ctx-chip" data-value="productivity">Personal productivity</button>
          <button class="ctx-chip" data-value="career">Career advancement</button>
          <button class="ctx-chip" data-value="team">Team leadership</button>
          <button class="ctx-chip" data-value="transformation">Business transformation</button>
        </div>
      </div>

      <button id="btn-ctx-start" class="btn-primary btn-lg" disabled>
        Begin Assessment
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <!-- STAGE 3: QUESTION -->
  <div id="s-question" class="stage" style="display:none">
    <div class="stage-body stage-narrow">
      <div class="q-top">
        <span id="q-section-label" class="chip"></span>
        <span id="q-num" class="q-num-text"></span>
      </div>
      <div class="q-progress-track">
        <div id="q-progress-fill" class="q-progress-fill"></div>
      </div>
      <div id="q-content" class="q-content"></div>
      <button id="btn-next" class="btn-primary btn-lg" disabled>
        Next
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <!-- STAGE 4: CALCULATING -->
  <div id="s-calc" class="stage" style="display:none">
    <div class="stage-body center-body">
      <div class="calc-ring">
        <svg width="80" height="80" viewBox="0 0 80 80">
          <circle cx="40" cy="40" r="34" fill="none" stroke="rgba(0,207,255,0.15)" stroke-width="4"/>
          <circle cx="40" cy="40" r="34" fill="none" stroke="#00CFFF" stroke-width="4"
            stroke-dasharray="213" stroke-dashoffset="213" stroke-linecap="round"
            transform="rotate(-90 40 40)" id="calc-arc"/>
        </svg>
      </div>
      <h2 class="calc-h2">Calculating your AIQ</h2>
      <p class="calc-sub">Analysing Think · Apply · Lead dimensions</p>
    </div>
  </div>

</div><!-- /aiq-app -->

<style>
  /* ── NAV ──────────────────────────────────────────── */
  .a-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(4, 7, 15, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0, 207, 255, 0.08);
    height: 60px;
  }
  .a-nav-inner {
    max-width: 720px;
    margin: 0 auto;
    height: 100%;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .a-nav-logo { display: flex; align-items: center; text-decoration: none; }
  .a-nav-prog {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  /* ── APP CONTAINER ──────────────────────────────── */
  #aiq-app { min-height: calc(100vh - 60px); }

  /* ── STAGE SYSTEM ───────────────────────────────── */
  .stage {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 60px);
  }
  .stage-body {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
    width: 100%;
  }
  .stage-narrow { max-width: 620px; }
  .center-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-top: 5rem;
  }

  /* ── WELCOME STAGE ──────────────────────────────── */
  .welcome-h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    font-family: 'Space Grotesk', sans-serif;
    margin-bottom: 1.25rem;
    line-height: 1.1;
  }
  .welcome-sub {
    font-size: 1.15rem;
    color: var(--muted);
    max-width: 480px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  .welcome-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 2.5rem;
    font-family: 'JetBrains Mono', monospace;
  }
  .welcome-meta .sep { opacity: 0.4; }
  .dims-row {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .dim-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.85rem 1.25rem;
    border-radius: 12px;
    border: 1px solid;
    min-width: 90px;
  }
  .dim-badge.dim-think { border-color: rgba(0,207,255,0.3); background: rgba(0,207,255,0.06); }
  .dim-badge.dim-apply { border-color: rgba(124,58,237,0.4); background: rgba(124,58,237,0.08); }
  .dim-badge.dim-lead  { border-color: rgba(0,207,255,0.2); background: rgba(0,207,255,0.04); }
  .dim-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .dim-pct {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.1rem;
    font-weight: 700;
    background: linear-gradient(135deg, #00CFFF, #7C3AED);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .btn-lg { padding: 1rem 2.5rem; font-size: 1rem; }
  .fine-print {
    margin-top: 1.25rem;
    font-size: 0.78rem;
    color: var(--muted);
    opacity: 0.7;
  }

  /* ── CONTEXT STAGE ──────────────────────────────── */
  .stage-h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
    font-weight: 800;
    font-family: 'Space Grotesk', sans-serif;
    margin-bottom: 0.75rem;
  }
  .stage-sub {
    color: var(--muted);
    font-size: 1rem;
    margin-bottom: 2.5rem;
    line-height: 1.65;
  }
  .ctx-group { margin-bottom: 2rem; }
  .ctx-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }
  .ctx-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .ctx-chip {
    padding: 0.55rem 1.1rem;
    border-radius: 999px;
    border: 1px solid rgba(0,207,255,0.35);
    background: transparent;
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .ctx-chip:hover {
    border-color: rgba(0,207,255,0.55);
    background: rgba(0,207,255,0.07);
  }
  .ctx-chip:active {
    background: rgba(0,207,255,0.15);
    border-color: var(--cyan);
    transform: scale(0.97);
  }
  .ctx-chip.selected {
    border-color: var(--cyan);
    background: rgba(0,207,255,0.18);
    color: var(--text);
    box-shadow: 0 0 12px rgba(0,207,255,0.15);
  }

  /* ── QUESTION STAGE ─────────────────────────────── */
  .q-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .q-num-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    color: var(--muted);
  }
  .q-progress-track {
    height: 3px;
    background: rgba(0,207,255,0.1);
    border-radius: 999px;
    margin-bottom: 2.5rem;
    overflow: hidden;
  }
  .q-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #00CFFF, #7C3AED);
    border-radius: 999px;
    transition: width 0.5s ease;
    width: 0%;
  }
  .q-content {
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .q-scenario {
    background: rgba(0,207,255,0.05);
    border: 1px solid rgba(0,207,255,0.15);
    border-left: 3px solid var(--cyan);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.75rem;
  }
  .q-scenario-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 0.5rem;
    font-family: 'Space Grotesk', sans-serif;
  }
  .q-scenario-body {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.6;
    white-space: pre-wrap;
  }
  .q-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.05rem, 2.5vw, 1.25rem);
    font-weight: 600;
    line-height: 1.45;
    margin-bottom: 1.75rem;
    color: var(--text);
  }
  .q-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .option-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: rgba(10, 18, 40, 0.6);
    border: 1px solid rgba(0,207,255,0.28);
    border-radius: 12px;
    cursor: pointer;
    text-align: left;
    width: 100%;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    font-family: 'Inter', sans-serif;
    -webkit-tap-highlight-color: transparent;
  }
  .option-card:hover {
    border-color: rgba(0,207,255,0.5);
    background: rgba(0,207,255,0.05);
  }
  .option-card:active {
    background: rgba(0,207,255,0.12);
    border-color: var(--cyan);
    transform: scale(0.99);
  }
  .option-card.selected {
    border-color: var(--cyan);
    background: rgba(0,207,255,0.13);
    box-shadow: 0 0 0 1px rgba(0,207,255,0.4), 0 0 20px rgba(0,207,255,0.15);
  }
  .option-toggle {
    width: 20px;
    height: 20px;
    min-width: 20px;
    border-radius: 50%;
    border: 2px solid rgba(0,207,255,0.4);
    background: transparent;
    position: relative;
    margin-top: 2px;
    transition: border-color 0.2s;
  }
  .option-toggle::after {
    content: '';
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    background: linear-gradient(135deg, #00CFFF, #7C3AED);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .option-card:hover .option-toggle {
    border-color: rgba(0,207,255,0.65);
  }
  .option-card.selected .option-toggle {
    border-color: var(--cyan);
  }
  .option-card.selected .option-toggle::after {
    opacity: 1;
  }
  .option-text {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--text);
    padding-top: 3px;
  }

  /* ── CALCULATING STAGE ──────────────────────────── */
  .calc-ring {
    margin-bottom: 2rem;
    animation: calcSpin 1.4s ease-in-out infinite;
  }
  @keyframes calcSpin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  #calc-arc {
    animation: calcFill 2s ease-in-out infinite alternate;
  }
  @keyframes calcFill {
    from { stroke-dashoffset: 180; }
    to   { stroke-dashoffset: 40; }
  }
  .calc-h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .calc-sub { color: var(--muted); font-size: 0.95rem; }

  /* ── DISABLED BTN OVERRIDE ──────────────────────── */
  .btn-primary:disabled {
    opacity: 0.35;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }
</style>

<script>
(function () {
  // ─────────────────────────────────────────────────────
  //  QUESTION DATA
  // ─────────────────────────────────────────────────────
  // d = dimensions: t=think, a=apply, l=lead (weights, sum to 1)
  // c = correct option index (0-based)
  // ctx = optional scenario context (null if none)

  const QA = [
    {id:'A1', sl:'AI AWARENESS', d:{t:1},
     q:'Which best describes how large language models (LLMs) generate text?',
     ctx:null,
     opts:['They search the internet in real time and synthesise the best answers',
           'They predict the most likely next token based on patterns learned during training',
           'They retrieve pre-written answers from a curated knowledge base',
           'They simulate human reasoning by running logical inference rules'],
     c:1},
    {id:'A2', sl:'AI AWARENESS', d:{t:1},
     q:'You ask AI to draft a legal contract. It produces a confident, well-formatted document. What\'s the most important next step?',
     ctx:null,
     opts:['Run it through a grammar and spell-checker',
           'Ask the AI to review its own work for accuracy',
           'Have a qualified lawyer review it for accuracy and legal compliance',
           'Format it to match your company\'s standard template'],
     c:2},
    {id:'A3', sl:'AI AWARENESS', d:{t:1},
     q:'What does "hallucination" mean in the context of AI language models?',
     ctx:null,
     opts:['The model creates visual imagery when processing complex text',
           'The model generates confident-sounding but factually incorrect information',
           'The model becomes confused when given contradictory instructions',
           'The model starts repeating the same output in a loop'],
     c:1},
    {id:'A4', sl:'AI AWARENESS', d:{t:1},
     q:'Which statement about AI model "context windows" is most accurate?',
     ctx:null,
     opts:['They determine how many users can access the model simultaneously',
           'They set a daily usage limit that resets every 24 hours',
           'They define the maximum amount of text (input + output) the model can process at once',
           'They control the creativity and randomness of model responses'],
     c:2},
  ];

  const QBe = [
    {id:'B1e', sl:'PROMPT MASTERY', d:{t:0.5,a:0.5},
     q:'You want AI to summarise an article for your manager. Which prompt gets the best result?',
     ctx:null,
     opts:['"Summarise this."',
           '"Please summarise this article for me, thanks."',
           '"Summarise this article in 3 bullet points, focusing on the key business implications, for a non-technical manager."',
           '"Article summary needed ASAP."'],
     c:2},
    {id:'B2e', sl:'PROMPT MASTERY', d:{t:0.5,a:0.5},
     q:'You ask AI a question and get a vague, generic response. What should you do first?',
     ctx:null,
     opts:['Accept the answer — AI is often vague on complex topics',
           'Ask the exact same question again',
           'Rephrase your question with more specific detail about what you actually need',
           'Switch to a different AI tool'],
     c:2},
    {id:'B3e', sl:'PROMPT MASTERY', d:{t:0.5,a:0.5},
     q:'You want AI to write a job description. What information should you provide?',
     ctx:null,
     opts:['Just the job title',
           'Ask AI to write a generic version for that role, then edit it',
           'The job title, key responsibilities, required skills, team context, and preferred tone',
           'Paste a competitor\'s job description and ask AI to rewrite it'],
     c:2},
    {id:'B4e', sl:'PROMPT MASTERY', d:{t:0.5,a:0.5},
     q:'What is the most appropriate response to this AI output?',
     ctx:'An AI states: "The global EV market will reach $800 billion by 2027." No sources are cited.',
     opts:['Use the statistic — AI is usually accurate on market data',
           'Ask AI to expand the analysis further',
           'Verify this specific claim in a primary source before using it',
           'Ask AI to add citations (it will generate accurate ones)'],
     c:2},
    {id:'B5e', sl:'PROMPT MASTERY', d:{t:0.5,a:0.5},
     q:'What is the main issue with this AI response?',
     ctx:'You ask: "What\'s the best marketing strategy?" AI responds: "The best marketing strategy depends on your goals, audience, and budget."',
     opts:['It\'s too short to be useful',
           'It\'s technically correct but gives no actionable guidance — the question needed more context',
           'The AI is wrong — there is one universally best strategy',
           'You should have used a marketing-specific AI tool'],
     c:1},
  ];

  const QBs = [
    {id:'B1s', sl:'PROMPT MASTERY', d:{t:0.5,a:0.5},
     q:'You need a 500-word blog introduction about remote work trends for HR managers. Which prompt gets the best result?',
     ctx:null,
     opts:['"Write a blog post about remote work."',
           '"Write about remote work trends in 500 words."',
           '"Write a compelling 500-word introduction for a blog post targeting HR managers about 3 emerging remote work trends in 2025. Tone: conversational but authoritative. End with a hook into the main article."',
           '"You are a writer. Write about remote work trends. Make it good."'],
     c:2},
    {id:'B2s', sl:'PROMPT MASTERY', d:{t:0.5,a:0.5},
     q:'You\'re getting generic AI answers on a complex topic. Which technique most improves quality?',
     ctx:null,
     opts:['Ask the same question multiple times until you get a better response',
           'Make the question shorter and simpler',
           'Add role context, specify the output format, and provide an example of what "good" looks like',
           'Add "please" and "thank you" to increase response quality'],
     c:2},
    {id:'B3s', sl:'PROMPT MASTERY', d:{t:0.5,a:0.5},
     q:'You need AI to categorise customer feedback. Which prompt approach works best?',
     ctx:null,
     opts:['"Analyse this customer feedback: [text]"',
           '"Read this feedback and tell me what you think."',
           '"Summarise this for me: [text]"',
           '"You are a customer insights analyst. Categorise the following feedback into Positive/Negative/Neutral, then identify the top 3 themes. Format as a table. Feedback: [text]"'],
     c:3},
    {id:'B4s', sl:'PROMPT MASTERY', d:{t:0.5,a:0.5},
     q:'What is the most significant weakness of this AI response?',
     ctx:'An AI-generated market analysis states: "The global EV market will reach $800 billion by 2027, representing a 340% increase, as confirmed by multiple industry sources." No citations are provided.',
     opts:['The writing style is too formal for a market analysis',
           'The 340% figure seems unrealistically optimistic',
           'Specific claims are stated with high confidence but no sources are cited — making them unverifiable',
           'The analysis should have been longer'],
     c:2},
    {id:'B5s', sl:'PROMPT MASTERY', d:{t:0.5,a:0.5},
     q:'Which prompt will consistently produce the most useful answer?',
