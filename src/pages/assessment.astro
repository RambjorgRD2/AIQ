     c:3},
  ];

  // ─────────────────────────────────────────────────────
  //  TIERS
  // ─────────────────────────────────────────────────────
  const TIERS = [
    {tier:0, min:0,  max:15,  label:'Baseline',    desc:'AI is new territory — the opportunity ahead of you is massive.', track:'foundations'},
    {tier:1, min:16, max:30,  label:'Aware',        desc:'You know AI matters. Now it\'s time to build real habits.', track:'foundations'},
    {tier:2, min:31, max:45,  label:'Curious',      desc:'You\'re experimenting and learning fast. The fundamentals are clicking into place.', track:'foundations'},
    {tier:3, min:46, max:55,  label:'Practitioner', desc:'You use AI regularly and get real results. You\'re ahead of most.', track:'workflows'},
    {tier:4, min:56, max:65,  label:'Fluent',       desc:'AI is a natural part of your workflow. You think in systems, not just tools.', track:'workflows'},
    {tier:5, min:66, max:75,  label:'Advanced',     desc:'You build systems, not just use them. You see possibilities others miss.', track:'workflows'},
    {tier:6, min:76, max:84,  label:'Strategist',   desc:'You shape how teams and organisations use AI. Your leverage is multiplicative.', track:'leadership'},
    {tier:7, min:85, max:92,  label:'Leader',       desc:'You drive AI transformation at scale. You\'re in the top 5% of practitioners.', track:'leadership'},
    {tier:8, min:93, max:100, label:'Pioneer',      desc:'You define the field for others. The question now is what you build next.', track:'leadership'},
  ];

  function getTier(score) {
    return TIERS.find(t => score >= t.min && score <= t.max) || TIERS[0];
  }

  // ─────────────────────────────────────────────────────
  //  SCORING
  // ─────────────────────────────────────────────────────
  function calculateScores(answers, questions) {
    let tp=0, tm=0, ap=0, am=0, lp=0, lm=0;
    for (const q of questions) {
      const correct = answers[q.id] === q.c;
      const pts = correct ? 100 : 0;
      if (q.d.t) { tp += pts * q.d.t; tm += 100 * q.d.t; }
      if (q.d.a) { ap += pts * q.d.a; am += 100 * q.d.a; }
      if (q.d.l) { lp += pts * q.d.l; lm += 100 * q.d.l; }
    }
    const think = tm > 0 ? Math.round((tp / tm) * 100) : 50;
    const apply = am > 0 ? Math.round((ap / am) * 100) : 50;
    const lead  = lm > 0 ? Math.round((lp / lm) * 100) : 50;
    const aiq   = Math.round(think * 0.35 + apply * 0.45 + lead * 0.20);
    return { think, apply, lead, aiq };
  }

  function getSectionAScore(answers) {
    const correct = QA.filter(q => answers[q.id] === q.c).length;
    return (correct / QA.length) * 100;
  }

  // ─────────────────────────────────────────────────────
  //  INSIGHTS
  // ─────────────────────────────────────────────────────
  function getInsight(think, apply, lead) {
    const dims = [
      {k:'think', s:think, n:'Think'},
      {k:'apply', s:apply, n:'Apply'},
      {k:'lead',  s:lead,  n:'Lead'},
    ].sort((a,b) => b.s - a.s);

    const hi = dims[0], lo = dims[2];
    const gap = hi.s - lo.s;

    if (gap < 12) return 'Your three dimensions are remarkably balanced — a rare trait. The highest-leverage next move is deepening your Apply score to break into the next tier.';

    const map = {
      think_apply: `Your Think score is ${gap} pts above your Apply score. You have a strong conceptual foundation — the next unlock is translating that thinking into consistent daily practice.`,
      think_lead:  `Your Think score is ${gap} pts above your Lead score. You understand AI deeply — the next level is using that clarity to guide others and shape strategy.`,
      apply_think: `Your Apply score is ${gap} pts above your Think score. You\'re highly effective with AI tools. Strengthening your conceptual understanding will sharpen your instincts for when and how to use them.`,
      apply_lead:  `Your Apply score is ${gap} pts above your Lead score. You\'re a hands-on practitioner ready to step into strategy. The next move is multiplying your skills through others.`,
      lead_think:  `Your Lead score is ${gap} pts above your Think score. You have strong strategic instincts. Deepening your AI literacy will make those instincts sharper and harder to challenge.`,
      lead_apply:  `Your Lead score is ${gap} pts above your Apply score. You think strategically about AI but there\'s untapped power in your own daily workflows. Bridging that gap compounds your leadership impact.`,
    };

    return map[`${hi.k}_${lo.k}`] || 'Your profile shows clear strengths and clear growth edges. Focus on your lowest dimension first — that\'s where the biggest lever is.';
  }

  // ─────────────────────────────────────────────────────
  //  STATE
  // ─────────────────────────────────────────────────────
  const state = {
    context: {},
    questionSet: [...QA],
    currentIndex: 0,
    answers: {},
    routingDone: false,
    difficulty: 'standard',
    pendingAnswer: null,
  };

  const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
  const TOTAL_QUESTIONS = 22;

  // ─────────────────────────────────────────────────────
  //  STAGE MANAGEMENT
  // ─────────────────────────────────────────────────────
  function showStage(id) {
    ['s-welcome','s-context','s-question','s-calc'].forEach(sid => {
      const el = document.getElementById(sid);
      if (el) el.style.display = 'none';
    });
    const target = document.getElementById(id);
    if (!target) return;
    target.style.display = 'flex';
    target.style.opacity = '0';
    target.style.transform = 'translateY(16px)';
    target.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
    requestAnimationFrame(() => requestAnimationFrame(() => {
      target.style.opacity = '1';
      target.style.transform = 'translateY(0)';
    }));
  }

  // ─────────────────────────────────────────────────────
  //  WELCOME STAGE
  // ─────────────────────────────────────────────────────
  document.getElementById('btn-start').addEventListener('click', () => {
    showStage('s-context');
  });

  // ─────────────────────────────────────────────────────
  //  CONTEXT STAGE
  // ─────────────────────────────────────────────────────
  const contextSelections = {};

  document.querySelectorAll('.ctx-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const group = chip.closest('[data-group]').dataset.group;
      chip.closest('.ctx-chips').querySelectorAll('.ctx-chip').forEach(c => c.classList.remove('selected'));
      chip.classList.add('selected');
      contextSelections[group] = chip.dataset.value;
      checkContextComplete();
    });
  });

  function checkContextComplete() {
    const required = ['role','domain','experience','goal'];
    const done = required.every(k => contextSelections[k]);
    document.getElementById('btn-ctx-start').disabled = !done;
  }

  document.getElementById('btn-ctx-start').addEventListener('click', () => {
    state.context = { ...contextSelections };
    startQuestions();
  });

  // ─────────────────────────────────────────────────────
  //  QUESTION STAGE
  // ─────────────────────────────────────────────────────
  function startQuestions() {
    showStage('s-question');
    renderQuestion();
  }

  function renderQuestion() {
    const q = state.questionSet[state.currentIndex];
    const idx = state.currentIndex;
    const total = TOTAL_QUESTIONS;

    // Update nav progress
    document.getElementById('nav-progress').textContent = `${idx + 1} / ${total}`;

    // Update header
    document.getElementById('q-section-label').textContent = q.sl;
    document.getElementById('q-num').textContent = `${idx + 1} / ${total}`;

    // Update progress bar
    document.getElementById('q-progress-fill').style.width = `${((idx + 1) / total) * 100}%`;

    // Build question HTML
    const ctxHtml = q.ctx
      ? `<div class="q-scenario"><div class="q-scenario-label">SCENARIO</div><div class="q-scenario-body">${q.ctx.replace(/\n/g,'<br>')}</div></div>`
      : '';

    const optsHtml = q.opts.map((opt, i) =>
      `<button class="option-card" data-idx="${i}" type="button">
        <span class="option-toggle"></span>
        <span class="option-text">${opt}</span>
      </button>`
    ).join('');

    const content = document.getElementById('q-content');

    // Fade out
    content.style.opacity = '0';
    content.style.transform = 'translateY(8px)';

    setTimeout(() => {
      content.innerHTML = `${ctxHtml}<p class="q-text">${q.q}</p><div class="q-options">${optsHtml}</div>`;
      content.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
      requestAnimationFrame(() => requestAnimationFrame(() => {
        content.style.opacity = '1';
        content.style.transform = 'translateY(0)';
      }));

      // Bind option clicks
      content.querySelectorAll('.option-card').forEach(card => {
        card.addEventListener('click', () => selectOption(parseInt(card.dataset.idx)));
      });
    }, 160);

    // Reset next button
    const nextBtn = document.getElementById('btn-next');
    nextBtn.disabled = true;
    state.pendingAnswer = null;

    // Update next button label for last question
    if (idx === total - 1) {
      nextBtn.innerHTML = `See My Results <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    } else {
      nextBtn.innerHTML = `Next <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
    }
  }

  function selectOption(idx) {
    document.querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
    document.querySelectorAll('.option-card')[idx]?.classList.add('selected');
    state.pendingAnswer = idx;
    document.getElementById('btn-next').disabled = false;
  }

  document.getElementById('btn-next').addEventListener('click', () => {
    if (state.pendingAnswer === null) return;

    const q = state.questionSet[state.currentIndex];
    state.answers[q.id] = state.pendingAnswer;

    // Adaptive routing: after Section A (index 3), build full question set
    if (state.currentIndex === 3 && !state.routingDone) {
      state.routingDone = true;
      const aScore = getSectionAScore(state.answers);

      let bSet, cSet;
      if (aScore < 40) {
        bSet = QBe; cSet = QCe; state.difficulty = 'easy';
      } else if (aScore > 70) {
        bSet = QBh; cSet = QCh; state.difficulty = 'hard';
      } else {
        bSet = QBs; cSet = QCs; state.difficulty = 'standard';
      }

      state.questionSet = [...QA, ...bSet, ...cSet, ...QD, ...QE];
    }

    state.currentIndex++;

    if (state.currentIndex >= state.questionSet.length) {
      finishAssessment();
    } else {
      renderQuestion();
    }
  });

  // ─────────────────────────────────────────────────────
  //  FINISH & SAVE
  // ─────────────────────────────────────────────────────
  function finishAssessment() {
    showStage('s-calc');

    const scores = calculateScores(state.answers, state.questionSet);
    const tier = getTier(scores.aiq);
    const insight = getInsight(scores.think, scores.apply, scores.lead);

    const result = {
      context: state.context,
      scores,
      tier,
      insight,
      difficulty: state.difficulty,
      completedAt: new Date().toISOString(),
    };

    localStorage.setItem('aiq_latest_result', JSON.stringify(result));

    setTimeout(() => {
      window.location.href = BASE + '/results';
    }, 2400);
  }

  // Restore welcome stage visibility
  document.getElementById('s-welcome').style.display = 'flex';

})();
</script>

