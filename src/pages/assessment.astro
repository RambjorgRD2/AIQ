  // ─────────────────────────────────────────────────────
  //  POOL CONFIGURATION
  //  Wraps each question array with its per-run pick count.
  //  To expand a pool in Phase 2: add questions to the source
  //  array above and increase pick if desired — nothing else changes.
  // ─────────────────────────────────────────────────────
  const POOLS = {
    A:  { questions: QA,  pick: 4 },
    Be: { questions: QBe, pick: 5 },
    Bs: { questions: QBs, pick: 5 },
    Bh: { questions: QBh, pick: 5 },
    Ce: { questions: QCe, pick: 5 },
    Cs: { questions: QCs, pick: 5 },
    Ch: { questions: QCh, pick: 5 },
    D:  { questions: QD,  pick: 4 },
    E:  { questions: QE,  pick: 4 },
  };

  const TOTAL_QUESTIONS = 22; // A(4) + B(5) + C(5) + D(4) + E(4)

  // ─────────────────────────────────────────────────────
  //  TIERS
  // ─────────────────────────────────────────────────────
  const TIERS = [
    {tier:0, min:0,  max:15,  label:'Baseline',    desc:'AI is new territory — the opportunity ahead of you is massive.', track:'foundations'},
    {tier:1, min:16, max:30,  label:'Aware',        desc:'You know AI matters. Now it\'s time to build real habits.', track:'foundations'},
    {tier:2, min:31, max:45,  label:'Curious',      desc:'You\'re experimenting and learning fast. The fundamentals are clicking into place.', track:'foundations'},
    {tier:3, min:46, max:55,  label:'Practitioner', desc:'You use AI regularly and get real results. You\'re ahead of most.', track:'workflows'},
    {tier:4, min:56, max:65,  label:'Fluent',       desc:'AI is a natural part of your workflow. You think in systems, not just tools.', track:'workflows'},
    {tier:5, min:66, max:75,  label:'Advanced',     desc:'You build systems, not just use them. You see possibilities others miss.', track:'workflows'},
    {tier:6, min:76, max:84,  label:'Strategist',   desc:'You shape how teams and organisations use AI. Your leverage is multiplicative.', track:'leadership'},
    {tier:7, min:85, max:92,  label:'Leader',       desc:'You drive AI transformation at scale. You\'re in the top 5% of practitioners.', track:'leadership'},
    {tier:8, min:93, max:100, label:'Pioneer',      desc:'You define the field for others. The question now is what you build next.', track:'leadership'},
  ];

  // ─────────────────────────────────────────────────────
  //  UTILITY — SHUFFLE & POOL SELECTION
  // ─────────────────────────────────────────────────────

  // Unbiased Fisher-Yates shuffle. Returns a new array — never mutates input.
  function fisherYates(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  // Select n questions from a pool, prioritising questions not in seenIds.
  // Within each group (unseen / seen) the order is independently randomised.
  // If the pool has fewer than n questions, all are returned (no undefined slots).
  function pickFromPool(pool, n, seenIds) {
    const available = Math.min(n, pool.length);
    if (pool.length <= n) return fisherYates([...pool]);
    const unseen = fisherYates(pool.filter(q => !seenIds.includes(q.id)));
    const seen   = fisherYates(pool.filter(q =>  seenIds.includes(q.id)));
    return [...unseen, ...seen].slice(0, available);
  }

  // ─────────────────────────────────────────────────────
  //  UTILITY — VARIABLE INJECTION
  //  buildVarMap scans all question text once and picks ONE
  //  random value per {{key}}, returning a stable map.
  //  applyVars replaces all {{key}} occurrences using that map.
  //  Both calls within prepareQuestion() use the same map,
  //  so stem, ctx, and options are always internally consistent.
  // ─────────────────────────────────────────────────────
  function buildVarMap(allText) {
    const vars = {};
    const re = /\{\{(\w+)\}\}/g;
    let m;
    while ((m = re.exec(allText)) !== null) {
      const key = m[1];
      if (!(key in vars) && SCENARIO_VARS[key]) {
        const pool = SCENARIO_VARS[key];
        vars[key] = pool[Math.floor(Math.random() * pool.length)];
      }
    }
    return vars;
  }

  function applyVars(text, vars) {
    return text.replace(/\{\{(\w+)\}\}/g, (_, k) => (k in vars ? vars[k] : `{{${k}}}`));
  }

  // Prepare a question for display: shuffle options, inject variables, store correctText.
  // Returns a new object — source question data is never mutated.
  // correctText is set here and used by calculateScores; it is immune to shuffle order.
  function prepareQuestion(q) {
    const allText    = [q.q, q.ctx || '', ...q.opts].join('\0');
    const vars       = buildVarMap(allText);                  // one map, applied everywhere
    const rawCorrect = q.opts[q.c];                           // correct text before any changes
    const shuffled   = fisherYates([...q.opts]);              // shuffle a copy
    return {
      ...q,
      q:           applyVars(q.q, vars),
      ctx:         q.ctx ? applyVars(q.ctx, vars) : null,
      opts:        shuffled.map(o => applyVars(o, vars)),
      correctText: applyVars(rawCorrect, vars),               // injected, shuffle-immune
    };
  }

  // ─────────────────────────────────────────────────────
  //  ATTEMPT HISTORY  (localStorage, cross-session)
  //  Tracks which question IDs have been shown so pickFromPool
  //  can prioritise unseen questions on subsequent attempts.
  //  Both functions are called only in finishAssessment() —
  //  abandoned sessions do not pollute the history.
  // ─────────────────────────────────────────────────────
  const LS_SEEN_IDS    = 'aiq_seen_ids';
  const LS_ATTEMPT_CTR = 'aiq_attempt_count';

  function getSeenIds() {
    try { return JSON.parse(localStorage.getItem(LS_SEEN_IDS) || '[]'); }
    catch { return []; }
  }

  function addSeenIds(ids) {
    // Cap at 500 entries to stay well within localStorage limits
    const updated = [...new Set([...getSeenIds(), ...ids])].slice(-500);
    try { localStorage.setItem(LS_SEEN_IDS, JSON.stringify(updated)); }
    catch { /* storage full or blocked — degrade silently */ }
  }

  function getAttemptCount() {
    return parseInt(localStorage.getItem(LS_ATTEMPT_CTR) || '0', 10);
  }

  function incrementAttemptCount() {
    try { localStorage.setItem(LS_ATTEMPT_CTR, String(getAttemptCount() + 1)); }
    catch { /* degrade silently */ }
  }

  // ─────────────────────────────────────────────────────
  //  SCORING
  //  Compares stored answer text against correctText set by
  //  prepareQuestion(). Position-independent — shuffle-immune.
  // ─────────────────────────────────────────────────────
  function calculateScores(answers, questions) {
    let tp=0, tm=0, ap=0, am=0, lp=0, lm=0;
    for (const q of questions) {
      const correct = answers[q.id] === q.correctText;
      const pts = correct ? 100 : 0;
      if (q.d.t) { tp += pts * q.d.t; tm += 100 * q.d.t; }
      if (q.d.a) { ap += pts * q.d.a; am += 100 * q.d.a; }
      if (q.d.l) { lp += pts * q.d.l; lm += 100 * q.d.l; }
    }
    const think = tm > 0 ? Math.round((tp / tm) * 100) : 50;
    const apply = am > 0 ? Math.round((ap / am) * 100) : 50;
    const lead  = lm > 0 ? Math.round((lp / lm) * 100) : 50;
    const aiq   = Math.round(think * 0.35 + apply * 0.45 + lead * 0.20);
    return { think, apply, lead, aiq };
  }

  // Pass the live questionSet (not the source array) so correctText is available.
  function getSectionAScore(answers, questions) {
    const sectionA = questions.filter(q => q.id.startsWith('A'));
    if (!sectionA.length) return 0;
    return (sectionA.filter(q => answers[q.id] === q.correctText).length / sectionA.length) * 100;
  }

  function getTier(score) {
    return TIERS.find(t => score >= t.min && score <= t.max) || TIERS[0];
  }

  // ─────────────────────────────────────────────────────
  //  INSIGHTS
  // ─────────────────────────────────────────────────────
  function getInsight(think, apply, lead) {
    const dims = [
      {k:'think', s:think},
      {k:'apply', s:apply},
      {k:'lead',  s:lead},
    ].sort((a,b) => b.s - a.s);

    const hi = dims[0], lo = dims[2];
    const gap = hi.s - lo.s;

    if (gap < 12) return 'Your three dimensions are remarkably balanced — a rare trait. The highest-leverage next move is deepening your Apply score to break into the next tier.';

    const map = {
      think_apply: `Your Think score is ${gap} pts above your Apply score. You have a strong conceptual foundation — the next unlock is translating that thinking into consistent daily practice.`,
      think_lead:  `Your Think score is ${gap} pts above your Lead score. You understand AI deeply — the next level is using that clarity to guide others and shape strategy.`,
      apply_think: `Your Apply score is ${gap} pts above your Think score. You\'re highly effective with AI tools. Strengthening your conceptual understanding will sharpen your instincts for when and how to use them.`,
      apply_lead:  `Your Apply score is ${gap} pts above your Lead score. You\'re a hands-on practitioner ready to step into strategy. The next move is multiplying your skills through others.`,
      lead_think:  `Your Lead score is ${gap} pts above your Think score. You have strong strategic instincts. Deepening your AI literacy will make those instincts sharper and harder to challenge.`,
      lead_apply:  `Your Lead score is ${gap} pts above your Apply score. You think strategically about AI but there\'s untapped power in your own daily workflows. Bridging that gap compounds your leadership impact.`,
    };

    return map[`${hi.k}_${lo.k}`] || 'Your profile shows clear strengths and clear growth edges. Focus on your lowest dimension first — that\'s where the biggest lever is.';
  }

  // ─────────────────────────────────────────────────────
  //  STATE
  // ─────────────────────────────────────────────────────
  const state = {
    context:      {},
    questionSet:  [],   // prepared questions (shuffled opts, injected vars, correctText set)
    currentIndex: 0,
    answers:      {},   // { questionId: selectedOptionText }
    routingDone:  false,
    difficulty:   'standard',
    pendingAnswer: null, // text of the selected option awaiting confirmation
  };

  const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

  // ─────────────────────────────────────────────────────
  //  STAGE MANAGEMENT
  // ─────────────────────────────────────────────────────
  function showStage(id) {
    ['s-welcome','s-context','s-question','s-calc'].forEach(sid => {
      const el = document.getElementById(sid);
      if (el) el.style.display = 'none';
    });
    const target = document.getElementById(id);
    if (!target) return;
    target.style.display    = 'flex';
    target.style.opacity    = '0';
    target.style.transform  = 'translateY(16px)';
    target.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
    requestAnimationFrame(() => requestAnimationFrame(() => {
      target.style.opacity   = '1';
      target.style.transform = 'translateY(0)';
    }));
  }

  // ─────────────────────────────────────────────────────
  //  WELCOME — returning-user awareness
  //  Shows on the 2nd attempt onward. Count is incremented
  //  only on completion, so abandoned attempts don't count.
  // ─────────────────────────────────────────────────────
  (function initWelcome() {
    const count = getAttemptCount(); // completed assessments so far
    if (count > 0) {
      const el = document.querySelector('.fine-print');
      if (el) {
        // Ordinal suffix — handles 11th/12th/13th edge cases correctly
        const n = count + 1; // this attempt number
        const mod100 = n % 100;
        const mod10  = n % 10;
        let suffix;
        if (mod100 >= 11 && mod100 <= 13)      suffix = 'th';
        else if (mod10 === 1)                   suffix = 'st';
        else if (mod10 === 2)                   suffix = 'nd';
        else if (mod10 === 3)                   suffix = 'rd';
        else                                    suffix = 'th';
        el.textContent = `Your ${n}${suffix} assessment — questions and answer order adapt each time.`;
      }
    }
  })();

  document.getElementById('btn-start').addEventListener('click', () => {
    showStage('s-context');
  });

  // ─────────────────────────────────────────────────────
  //  CONTEXT STAGE
  // ─────────────────────────────────────────────────────
  const contextSelections = {};

  document.querySelectorAll('.ctx-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const group = chip.closest('[data-group]').dataset.group;
      chip.closest('.ctx-chips').querySelectorAll('.ctx-chip').forEach(c => c.classList.remove('selected'));
      chip.classList.add('selected');
      contextSelections[group] = chip.dataset.value;
      checkContextComplete();
    });
  });

  function checkContextComplete() {
    const required = ['role','domain','experience','goal'];
    document.getElementById('btn-ctx-start').disabled = !required.every(k => contextSelections[k]);
  }

  document.getElementById('btn-ctx-start').addEventListener('click', () => {
    state.context = { ...contextSelections };
    startQuestions();
  });

  // ─────────────────────────────────────────────────────
  //  QUESTION STAGE
  // ─────────────────────────────────────────────────────
  function startQuestions() {
    const seenIds = getSeenIds();
    // Pick Section A questions from the pool (unseen first), then prepare each one.
    // prepareQuestion() is called exactly once per question — never again during the session.
    const aRaw = pickFromPool(POOLS.A.questions, POOLS.A.pick, seenIds);
    state.questionSet = aRaw.map(prepareQuestion);
    showStage('s-question');
    renderQuestion();
  }

  function renderQuestion() {
    const q   = state.questionSet[state.currentIndex];
    const idx = state.currentIndex;

    document.getElementById('nav-progress').textContent      = `${idx + 1} / ${TOTAL_QUESTIONS}`;
    document.getElementById('q-section-label').textContent   = q.sl;
    document.getElementById('q-num').textContent             = `${idx + 1} / ${TOTAL_QUESTIONS}`;
    document.getElementById('q-progress-fill').style.width   = `${((idx + 1) / TOTAL_QUESTIONS) * 100}%`;

    const ctxHtml = q.ctx
      ? `<div class="q-scenario"><div class="q-scenario-label">SCENARIO</div><div class="q-scenario-body">${q.ctx.replace(/\n/g,'<br>')}</div></div>`
      : '';

    // data-idx references position in the already-shuffled opts array
    const optsHtml = q.opts.map((opt, i) =>
      `<button class="option-card" data-idx="${i}" type="button">
        <span class="option-radio"><span class="option-radio-dot"></span></span>
        <span class="option-text">${opt}</span>
      </button>`
    ).join('');

    const content = document.getElementById('q-content');
    content.style.opacity   = '0';
    content.style.transform = 'translateY(8px)';

    setTimeout(() => {
      content.innerHTML = `${ctxHtml}<p class="q-text">${q.q}</p><div class="q-options">${optsHtml}</div>`;
      content.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
      requestAnimationFrame(() => requestAnimationFrame(() => {
        content.style.opacity   = '1';
        content.style.transform = 'translateY(0)';
      }));

      content.querySelectorAll('.option-card').forEach(card => {
        card.addEventListener('click', () => {
          // Resolve the selected text from the prepared (shuffled) options.
          // Storing text — not index — makes the answer immune to future shuffles.
          const optText = state.questionSet[state.currentIndex].opts[parseInt(card.dataset.idx)];
          selectOption(card, optText);
        });
      });
    }, 160);

    const nextBtn = document.getElementById('btn-next');
    nextBtn.disabled  = true;
    state.pendingAnswer = null;
    nextBtn.innerHTML = idx === TOTAL_QUESTIONS - 1
      ? `See My Results <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`
      : `Next <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
  }

  function selectOption(card, optText) {
    document.querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');
    state.pendingAnswer = optText;
    document.getElementById('btn-next').disabled = false;
  }

  // ─────────────────────────────────────────────────────
  //  NEXT BUTTON & ADAPTIVE ROUTING
  // ─────────────────────────────────────────────────────
  document.getElementById('btn-next').addEventListener('click', () => {
    if (state.pendingAnswer === null) return;

    const q = state.questionSet[state.currentIndex];
    state.answers[q.id] = state.pendingAnswer;

    // After the last Section A question, determine difficulty and build the full set.
    // Routing fires BEFORE currentIndex is incremented.
    if (state.currentIndex === POOLS.A.pick - 1 && !state.routingDone) {
      state.routingDone = true;
      const aScore = getSectionAScore(state.answers, state.questionSet);

      let bPool, cPool;
      if (aScore < 40) {
        bPool = POOLS.Be; cPool = POOLS.Ce; state.difficulty = 'easy';
      } else if (aScore > 70) {
        bPool = POOLS.Bh; cPool = POOLS.Ch; state.difficulty = 'hard';
      } else {
        bPool = POOLS.Bs; cPool = POOLS.Cs; state.difficulty = 'standard';
      }

      // Combine historical seen IDs with the current session's A questions
      // to maximise variety across all remaining sections.
      const sessionIds = state.questionSet.map(item => item.id);
      const allSeen    = [...new Set([...getSeenIds(), ...sessionIds])];

      const bRaw = pickFromPool(bPool.questions, bPool.pick, allSeen);
      const cRaw = pickFromPool(cPool.questions, cPool.pick, allSeen);
      const dRaw = pickFromPool(POOLS.D.questions, POOLS.D.pick, allSeen);
      const eRaw = pickFromPool(POOLS.E.questions, POOLS.E.pick, allSeen);

      state.questionSet = [
        ...state.questionSet,
        ...[...bRaw, ...cRaw, ...dRaw, ...eRaw].map(prepareQuestion),
      ];
    }

    state.currentIndex++;

    if (state.currentIndex >= state.questionSet.length) {
      finishAssessment();
    } else {
      renderQuestion();
    }
  });

  // ─────────────────────────────────────────────────────
  //  FINISH & SAVE
  //  History and counter are recorded here — only on a
  //  completed assessment. Abandoned sessions leave no trace.
  // ─────────────────────────────────────────────────────
  function finishAssessment() {
    showStage('s-calc');

    const scores  = calculateScores(state.answers, state.questionSet);
    const tier    = getTier(scores.aiq);
    const insight = getInsight(scores.think, scores.apply, scores.lead);

    const result = {
      context:     state.context,
      scores,
      tier,
      insight,
      difficulty:  state.difficulty,
      completedAt: new Date().toISOString(),
    };

    try { localStorage.setItem('aiq_latest_result', JSON.stringify(result)); }
    catch { /* storage blocked — results will not persist */ }

    // Supabase dual-write (fire-and-forget)
    ;(async () => {
      const { data: { session } } = await supabase.auth.getSession();
      if (session?.user) {
        upsertAssessmentResult({
          userId: session.user.id,
          score: result.scores.aiq,
          tier: String(result.tier.tier),
          tierLabel: result.tier.label || '',
          radarData: result.scores,
        }).catch(console.error);
      }
    })();

    // Record question IDs and increment counter only after full completion
    addSeenIds(state.questionSet.map(item => item.id));
    incrementAttemptCount();

    setTimeout(() => {
      window.location.href = BASE + '/results';
    }, 2400);
  }

  // Restore welcome stage visibility (Astro static render hides non-initial stages)
  document.getElementById('s-welcome').style.display = 'flex';

})();
</script>

</Layout>
