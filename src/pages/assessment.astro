  const QE = [
    {id:'E1', sl:'ETHICS & CRITICAL THINKING', d:{t:0.5,l:0.5},
     q:'An AI model produces a recommendation that perfectly aligns with your preferred outcome. Your most appropriate response is:',
     ctx:null,
     opts:['Implement it immediately — the AI has validated your thinking',
           'Share it with stakeholders as objective third-party validation',
