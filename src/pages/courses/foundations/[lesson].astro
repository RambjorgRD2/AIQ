---
import Layout from '../../../layouts/Layout.astro';
import { foundations, getLessonBySlug, getAdjacentLessons } from '../../../data/foundations-course';

export function getStaticPaths() {
  return foundations.map(lesson => ({
    params: { lesson: lesson.slug },
  }));
}

const { lesson: lessonSlug } = Astro.params;
const lesson = getLessonBySlug(lessonSlug as string)!;
const { prev, next } = getAdjacentLessons(lessonSlug as string);

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const totalModules = foundations.length;
const progressPct = Math.round((lesson.module / totalModules) * 100);
---

<Layout
  title={`${lesson.title} — AI~Foundations | AIQ`}
  description={lesson.subtitle}
>

<!-- TOP PROGRESS BAR -->
<div class="progress-bar-outer">
  <div class="progress-bar-inner" style={`width:${progressPct}%`}></div>
</div>

<!-- NAV -->
<nav class="l-nav">
  <div class="l-nav-inner">
    <a href={`${BASE}/`} class="l-nav-logo" aria-label="AIQ Home">
      <svg width="52" height="20" viewBox="0 0 72 28" fill="none">
        <text x="0" y="22" font-family="'Space Grotesk',sans-serif" font-size="22" font-weight="800" fill="url(#ln1)">AIQ</text>
        <path d="M2 26 Q18 21 36 26 Q54 21 70 26" stroke="url(#ln1)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
        <defs><linearGradient id="ln1" x1="0" y1="0" x2="72" y2="0" gradientUnits="userSpaceOnUse"><stop stop-color="#00CFFF"/><stop offset="1" stop-color="#7C3AED"/></linearGradient></defs>
      </svg>
    </a>

    <div class="l-breadcrumb">
      <a href={`${BASE}/courses`} class="l-breadcrumb-link">Courses</a>
      <span class="l-breadcrumb-sep">›</span>
      <a href={`${BASE}/courses/foundations`} class="l-breadcrumb-link">AI~Foundations</a>
      <span class="l-breadcrumb-sep">›</span>
      <span class="l-breadcrumb-current">Module {String(lesson.module).padStart(2,'0')}</span>
    </div>

    <div class="l-nav-meta">
      <span class="l-tier-badge">{lesson.tierLabel}</span>
      <span class="l-duration">{lesson.duration}</span>
    </div>
  </div>
</nav>

<!-- LESSON SHELL -->
<div class="lesson-shell">

  <!-- SIDEBAR -->
  <aside class="l-sidebar">
    <div class="l-sidebar-inner">
      <div class="l-sidebar-label">AI~Foundations</div>
      <div class="l-sidebar-progress">
        <div class="l-sidebar-progress-track">
          <div class="l-sidebar-progress-fill" style={`width:${progressPct}%`}></div>
        </div>
        <span class="l-sidebar-progress-label">{lesson.module}/{totalModules} modules</span>
      </div>

      <nav class="l-module-list">
        {foundations.map(m => (
          <a
            href={`${BASE}/courses/foundations/${m.slug}`}
            class={`l-module-item ${m.slug === lesson.slug ? 'active' : ''} ${m.module < lesson.module ? 'done' : ''}`}
          >
            <span class="l-module-num">{String(m.module).padStart(2,'0')}</span>
            <span class="l-module-title">{m.title}</span>
            {m.module < lesson.module && (
              <span class="l-module-check">✓</span>
            )}
          </a>
        ))}
      </nav>

      <a href={`${BASE}/assessment`} class="l-sidebar-cta">
        Take the AIQ Assessment →
      </a>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="l-main">

    <!-- LESSON HEADER -->
    <header class="l-header">
      <div class="l-module-badge">Module {String(lesson.module).padStart(2,'0')} · {lesson.tierLabel}</div>
      <h1 class="l-title">{lesson.title}</h1>
      <p class="l-subtitle">{lesson.subtitle}</p>
      <div class="l-meta">
        <span class="l-meta-pill">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#00CFFF" stroke-width="1.4"/><path d="M7 4v3l2 1.5" stroke="#00CFFF" stroke-width="1.4" stroke-linecap="round"/></svg>
          {lesson.duration}
        </span>
        <span class="l-meta-pill">{lesson.tierLabel}</span>
      </div>
    </header>

    <!-- HOOK -->
    <section class="l-section l-hook glass">
      <div class="l-section-eyebrow">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L9.5 6h4.5l-3.5 2.5L12 13 8 10.5 4 13l1.5-4.5L2 6h4.5L8 2z" stroke="#00CFFF" stroke-width="1.4" fill="none" stroke-linejoin="round"/></svg>
        Why This Matters
      </div>
      <p class="l-hook-text">{lesson.hook}</p>
    </section>

    <!-- CONCEPT -->
    <section class="l-section">
      <div class="l-section-eyebrow">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2" stroke="#00CFFF" stroke-width="1.4"/><path d="M5 8h6M5 5.5h6M5 10.5h4" stroke="#00CFFF" stroke-width="1.2" stroke-linecap="round"/></svg>
        The Concept
      </div>
      <div class="l-concept glass">
        <div class="l-concept-header">
          <span class="l-concept-label">Core Reading</span>
          <div class="l-concept-chips">
            <span class="l-concept-chip">{lesson.tierLabel}</span>
            <span class="l-concept-chip l-concept-chip--time">
              <svg width="11" height="11" viewBox="0 0 11 11" fill="none"><circle cx="5.5" cy="5.5" r="4.5" stroke="#00CFFF" stroke-width="1.1"/><path d="M5.5 3v2.5l1.25.9" stroke="#00CFFF" stroke-width="1.1" stroke-linecap="round"/></svg>
              {lesson.duration}
            </span>
          </div>
        </div>
        <div class="l-content-body" set:html={lesson.concept} />
      </div>
    </section>

    <!-- DEMO -->
    <section class="l-section">
      <div class="l-section-eyebrow">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 4l4 4-4 4M9 12h4" stroke="#00CFFF" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {lesson.demoTitle}
      </div>
      <div class="l-demo-card glass">
        <div class="l-content-body" set:html={lesson.demo} />
      </div>
    </section>

    <!-- EXERCISE -->
    <section class="l-section">
      <div class="l-section-eyebrow">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8a6 6 0 1 0 12 0A6 6 0 0 0 2 8zm4-2l4 2-4 2V6z" stroke="#7C3AED" stroke-width="1.4" fill="none" stroke-linejoin="round"/></svg>
        Hands-On Exercise
      </div>
      <div class="l-exercise glass">
        <div class="l-exercise-header">
          <h3 class="l-exercise-title">{lesson.exercise.title}</h3>
          <div class="l-exercise-tools">
            {lesson.exercise.tools.map(t => (
              <span class="l-tool-chip">{t}</span>
            ))}
          </div>
        </div>
        <div class="l-exercise-prompt" set:html={lesson.exercise.prompt} />
        <div class="l-exercise-hint">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#6B7A99" stroke-width="1.2"/><path d="M7 6v4M7 4.5v.5" stroke="#6B7A99" stroke-width="1.4" stroke-linecap="round"/></svg>
          <span>{lesson.exercise.hint}</span>
        </div>
      </div>
    </section>

    <!-- ACTIVE RECALL -->
    <section class="l-section">
      <div class="l-section-eyebrow">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M7 2C4.24 2 2 4.24 2 7c0 2.76 2.24 5 5 5s5-2.24 5-5c0-2.76-2.24-5-5-5zm0 9a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm1-3H6V5h2v3z" stroke="#00CFFF" stroke-width="1.2" fill="none"/></svg>
        Active Recall
      </div>
      <p class="l-recall-intro">Before moving on — close this lesson and answer these from memory. Then come back and check. Testing yourself (not re-reading) is how this sticks.</p>

      <div class="l-recall-list">
        {lesson.recall.map((q, i) => (
          <div class="l-recall-item glass" data-recall={i}>
            <div class="l-recall-q">
              <span class="l-recall-num">{i + 1}</span>
              <span>{q.q}</span>
            </div>
            <button class="l-recall-toggle" data-target={i}>
              Show hint
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 6l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
            </button>
            <div class="l-recall-hint" id={`hint-${i}`} hidden>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#6B7A99" stroke-width="1.2"/><path d="M7 6v4M7 4.5v.5" stroke="#6B7A99" stroke-width="1.4" stroke-linecap="round"/></svg>
              {q.hint}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- REFLECTION -->
    <section class="l-section">
      <div class="l-section-eyebrow">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2c1 0 4 1.5 4 5 0 2.5-2 4-4 4s-4-1.5-4-4c0-3.5 3-5 4-5z" stroke="#7C3AED" stroke-width="1.3" fill="none"/><path d="M8 11v3M6 14h4" stroke="#7C3AED" stroke-width="1.3" stroke-linecap="round"/></svg>
        Reflection
      </div>
      <div class="l-reflection glass">
        <div class="l-reflection-header">
          <span class="l-reflection-emoji">💭</span>
          <p class="l-reflection-prompt">{lesson.reflection}</p>
        </div>
        <textarea
          class="l-reflection-input"
          placeholder="Write your reflection here. This is for you — no one else sees it."
          rows="5"
          id="reflection-input"
        ></textarea>
        <button class="l-reflection-save" id="save-reflection">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7l4 4 6-7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Save locally
        </button>
        <span class="l-reflection-saved" id="reflection-saved" hidden>Saved ✓</span>
      </div>
    </section>

    <!-- KEY TAKEAWAY -->
    <section class="l-section">
      <div class="l-takeaway glass">
        <div class="l-takeaway-label">Key Takeaway</div>
        <p class="l-takeaway-text">{lesson.keyTakeaway}</p>
      </div>
    </section>

    <!-- NAVIGATION -->
    <nav class="l-lesson-nav">
      {prev ? (
        <a href={`${BASE}/courses/foundations/${prev.slug}`} class="l-nav-btn l-nav-btn--prev">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <div>
            <div class="l-nav-btn-label">Previous</div>
            <div class="l-nav-btn-title">{prev.title}</div>
          </div>
        </a>
      ) : (
        <a href={`${BASE}/courses/foundations`} class="l-nav-btn l-nav-btn--prev">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <div>
            <div class="l-nav-btn-label">Back to</div>
            <div class="l-nav-btn-title">Course Overview</div>
          </div>
        </a>
      )}

      {next ? (
        <button class="l-nav-btn l-nav-btn--next btn-primary" id="complete-btn" data-next={`${BASE}/courses/foundations/${next.slug}`}>
          <div>
            <div class="l-nav-btn-label">Next Module</div>
            <div class="l-nav-btn-title">{next.title}</div>
          </div>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      ) : (
        <a href={`${BASE}/courses/workflows`} class="l-nav-btn l-nav-btn--next btn-primary">
          <div>
            <div class="l-nav-btn-label">Course Complete! Up next:</div>
            <div class="l-nav-btn-title">AI~Workflows →</div>
          </div>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      )}
    </nav>

  </main>
</div>

<style is:global>
  /* ─── Progress bar ─── */
  .progress-bar-outer {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(0,207,255,0.1);
    z-index: 200;
  }
  .progress-bar-inner {
    height: 100%;
    background: linear-gradient(90deg, var(--cyan), var(--violet));
    transition: width 0.4s ease;
  }

  /* ─── Nav ─── */
  .l-nav {
    position: sticky;
    top: 3px;
    z-index: 100;
    background: rgba(4,7,15,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,207,255,0.08);
    height: 56px;
  }
  .l-nav-inner {
    max-width: 1300px;
    margin: 0 auto;
    height: 100%;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .l-nav-logo { display: flex; align-items: center; text-decoration: none; flex-shrink: 0; }
  .l-breadcrumb { display: flex; align-items: center; gap: 0.5rem; flex: 1; font-size: 0.84rem; }
  .l-breadcrumb-link { color: var(--muted); text-decoration: none; transition: color 0.2s; }
  .l-breadcrumb-link:hover { color: var(--cyan); }
  .l-breadcrumb-sep { color: rgba(107,122,153,0.4); }
  .l-breadcrumb-current { color: var(--text); font-weight: 500; }
  .l-nav-meta { display: flex; align-items: center; gap: 0.75rem; margin-left: auto; flex-shrink: 0; }
  .l-tier-badge {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(0,207,255,0.2);
    background: rgba(0,207,255,0.06);
    color: var(--cyan);
    font-family: 'Space Grotesk', sans-serif;
    white-space: nowrap;
  }
  .l-duration { font-size: 0.8rem; color: var(--muted); font-family: 'JetBrains Mono', monospace; white-space: nowrap; }
  @media(max-width:640px) { .l-breadcrumb { display: none; } .l-nav-meta { display: none; } }

  /* ─── Shell layout ─── */
  .lesson-shell {
    display: grid;
    grid-template-columns: 280px 1fr;
    min-height: calc(100vh - 59px);
    max-width: 1300px;
    margin: 0 auto;
  }
  @media(max-width:900px) { .lesson-shell { grid-template-columns: 1fr; } }

  /* ─── Sidebar ─── */
  .l-sidebar {
    border-right: 1px solid rgba(0,207,255,0.07);
    position: sticky;
    top: 59px;
    height: calc(100vh - 59px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(0,207,255,0.15) transparent;
  }
  @media(max-width:900px) { .l-sidebar { display: none; } }
  .l-sidebar-inner { padding: 1.5rem 1rem 3rem; }
  .l-sidebar-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 0.75rem;
  }
  .l-sidebar-progress { margin-bottom: 1.5rem; }
  .l-sidebar-progress-track {
    height: 3px;
    background: rgba(0,207,255,0.1);
    border-radius: 999px;
    margin-bottom: 0.4rem;
    overflow: hidden;
  }
  .l-sidebar-progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--cyan), var(--violet));
    border-radius: 999px;
  }
  .l-sidebar-progress-label { font-size: 0.72rem; color: var(--muted); font-family: 'JetBrains Mono', monospace; }

  .l-module-list { display: flex; flex-direction: column; gap: 2px; margin-bottom: 2rem; }
  .l-module-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.82rem;
    color: var(--muted);
    transition: background 0.2s, color 0.2s;
    position: relative;
  }
  .l-module-item:hover { background: rgba(0,207,255,0.05); color: var(--text); }
  .l-module-item.active { background: rgba(0,207,255,0.08); color: var(--cyan); font-weight: 600; }
  .l-module-item.done { color: rgba(107,122,153,0.7); }
  .l-module-item.done:hover { color: var(--text); }
  .l-module-num { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: inherit; opacity: 0.6; flex-shrink: 0; }
  .l-module-title { flex: 1; line-height: 1.3; }
  .l-module-check { color: var(--cyan); font-size: 0.7rem; flex-shrink: 0; opacity: 0.7; }

  .l-sidebar-cta {
    display: block;
    text-align: center;
    padding: 0.75rem;
    border-radius: 10px;
    background: rgba(0,207,255,0.06);
    border: 1px solid rgba(0,207,255,0.15);
    color: var(--cyan);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: 'Space Grotesk', sans-serif;
    transition: background 0.2s, border-color 0.2s;
  }
  .l-sidebar-cta:hover { background: rgba(0,207,255,0.1); border-color: rgba(0,207,255,0.3); }

  /* ─── Main content ─── */
  .l-main { padding: 3rem 3rem 6rem; max-width: 760px; }
  @media(max-width:1024px) { .l-main { padding: 2.5rem 2rem 5rem; } }
  @media(max-width:640px) { .l-main { padding: 2rem 1.25rem 4rem; } }

  /* ─── Lesson header ─── */
  .l-header { margin-bottom: 3rem; }
  .l-module-badge {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--cyan);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
    opacity: 0.8;
  }
  .l-title {
    font-size: clamp(1.9rem, 4vw, 2.75rem);
    font-weight: 800;
    font-family: 'Space Grotesk', sans-serif;
    line-height: 1.1;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, var(--text) 0%, rgba(232,240,255,0.75) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .l-subtitle { color: var(--muted); font-size: 1.05rem; line-height: 1.65; margin-bottom: 1.25rem; max-width: 580px; }
  .l-meta { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .l-meta-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    border: 1px solid rgba(0,207,255,0.15);
    background: rgba(0,207,255,0.04);
    font-size: 0.78rem;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
  }

  /* ─── Section shared ─── */
  .l-section { margin-bottom: 3rem; }
  .l-section-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  /* ─── Hook ─── */
  .l-hook { padding: 1.75rem 2rem; }
  .l-hook-text { font-size: 1.05rem; line-height: 1.8; color: var(--text); }

  /* ─── Concept card ─── */
  .l-concept { padding: 1.75rem 2rem; }
  .l-concept-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 1.25rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid rgba(0,207,255,0.1);
  }
  .l-concept-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--cyan);
  }
  .l-concept-chips { display: flex; gap: 0.4rem; align-items: center; }
  .l-concept-chip {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    background: rgba(0,207,255,0.07);
    border: 1px solid rgba(0,207,255,0.18);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--cyan);
    font-family: 'Space Grotesk', sans-serif;
  }

  /* ─── Concept body ─── */
  .l-content-body h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    margin: 2.5rem 0 1.25rem;
    color: var(--text);
    border-left: 3px solid rgba(0,207,255,0.6);
    padding-left: 0.85rem;
  }
  .l-content-body h2:first-child { margin-top: 0; }
  .l-content-body h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    margin: 1.5rem 0 0.5rem;
    color: var(--cyan);
  }
  .l-content-body p { margin-bottom: 1.85rem; line-height: 1.85; color: rgba(232,240,255,0.85); }
  .l-content-body ul, .l-content-body ol { margin: 0.75rem 0 1.25rem 1.25rem; }
  .l-content-body li { margin-bottom: 0.65rem; line-height: 1.75; color: rgba(232,240,255,0.8); }
  .c-lead-para {
    font-size: 1.05rem;
    line-height: 1.95;
    color: rgba(232,240,255,0.95);
