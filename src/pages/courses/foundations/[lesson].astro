  .l-nav-btn--next { justify-content: space-between; max-width: 340px; }
  .l-nav-btn-label { font-size: 0.72rem; color: rgba(232,240,255,0.5); margin-bottom: 0.2rem; font-family: 'Space Grotesk', sans-serif; text-transform: uppercase; letter-spacing: 0.06em; }
  .l-nav-btn-title { font-size: 0.9rem; font-weight: 600; font-family: 'Space Grotesk', sans-serif; }
  .l-nav-btn--prev .l-nav-btn-label { color: var(--muted); }
  .l-nav-btn--prev .l-nav-btn-title { color: var(--text); }
</style>

<script>
  // ── Hint toggles ──
  // Use style.display instead of the hidden attribute so that
  // the .l-recall-hint { display:flex } CSS rule doesn't override visibility.
  document.querySelectorAll('.l-recall-hint').forEach(el => {
    (el as HTMLElement).style.display = 'none';
  });

  document.querySelectorAll('.l-recall-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const i = btn.getAttribute('data-target');
      const hint = document.getElementById(`hint-${i}`) as HTMLElement | null;
      if (!hint) return;
      const isVisible = hint.style.display !== 'none';
      hint.style.display = isVisible ? 'none' : 'flex';
      btn.innerHTML = isVisible
        ? 'Show hint <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 6l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>'
        : 'Hide hint <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M4 8l3-3 3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>';
    });
  });

  // ── Reflection persistence ──
  const moduleSlug = location.pathname.split('/').filter(Boolean).pop();
  const storageKey = `reflection-${moduleSlug}`;
  const textarea = document.getElementById('reflection-input') as HTMLTextAreaElement;
  const saveBtn = document.getElementById('save-reflection');
  const savedMsg = document.getElementById('reflection-saved');

  if (textarea) {
    const saved = localStorage.getItem(storageKey);
    if (saved) textarea.value = saved;
  }

  saveBtn?.addEventListener('click', () => {
    if (textarea) {
      localStorage.setItem(storageKey, textarea.value);
      if (savedMsg) {
        savedMsg.hidden = false;
        setTimeout(() => { savedMsg.hidden = true; }, 2500);
      }
    }
  });

  // ── Mark module complete on "Next" ──
  const completeBtn = document.getElementById('complete-btn');
  completeBtn?.addEventListener('click', () => {
    const slug = location.pathname.split('/').filter(Boolean).pop();
    const completedKey = 'aiq-foundations-completed';
    const completed: string[] = JSON.parse(localStorage.getItem(completedKey) || '[]');
    if (slug && !completed.includes(slug)) {
      completed.push(slug);
      localStorage.setItem(completedKey, JSON.stringify(completed));
    }
    const next = completeBtn.getAttribute('data-next');
    if (next) window.location.href = next;
  });

  // ── Scroll reveal ──
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.opacity = '1';
        (e.target as HTMLElement).style.transform = 'translateY(0)';
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.05 });

  document.querySelectorAll('.l-section').forEach((el, i) => {
    const elem = el as HTMLElement;
    elem.style.opacity = '0';
    elem.style.transform = 'translateY(24px)';
    elem.style.transition = `opacity 0.6s ease ${i * 0.05}s, transform 0.6s ease ${i * 0.05}s`;
    obs.observe(elem);
  });
</script>

