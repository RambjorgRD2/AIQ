---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const NOTION_URL = 'https://walnut-sea-abb.notion.site/3213f9fc4e588013bacbe0f823a2ae09?pvs=105';

const modules = [
  { num:'01', title:'The AI Leader\'s Mindset', desc:'What separates AI leaders from AI users. The principles behind transformative adoption.' },
  { num:'02', title:'Organisational AI Readiness', desc:'How to assess your organisation\'s current state — capabilities, culture, and infrastructure.' },
  { num:'03', title:'Building the AI Strategy', desc:'From vision to roadmap. How to define AI priorities that align with business outcomes.' },
  { num:'04', title:'Change Management for AI', desc:'Why AI initiatives fail — and how to lead adoption through resistance, fear, and inertia.' },
  { num:'05', title:'AI Governance & Risk Frameworks', desc:'Policies, guardrails, and audit processes. Leading responsibly at scale.' },
  { num:'06', title:'Building AI-Capable Teams', desc:'Hiring, reskilling, and creating the conditions for AI excellence to spread.' },
  { num:'07', title:'The Ethics of AI at Scale', desc:'Bias, fairness, transparency, and the questions every leader must answer before deploying AI broadly.' },
  { num:'08', title:'AI & Competitive Strategy', desc:'How AI reshapes competitive advantage — and how to position your organisation to win.' },
  { num:'09', title:'Measuring AI Transformation', desc:'KPIs, ROI frameworks, and how to report AI impact to boards and executives.' },
  { num:'10', title:'AI Communication for Leaders', desc:'How to talk about AI with sceptics, regulators, media, and the public.' },
  { num:'11', title:'The Future of Work with AI', desc:'Workforce transition, role evolution, and leading through the structural changes ahead.' },
  { num:'12', title:'Live Event Leadership Lab', desc:'Applied leadership scenarios from real organisations — including the brAInstorm case studies.' },
  { num:'13', title:'AI Partnership & Procurement', desc:'How to evaluate, negotiate, and manage AI vendor relationships strategically.' },
  { num:'14', title:'The Pioneer Mindset', desc:'What it means to define the field. How Pioneer-tier practitioners think, act, and lead.' },
  { num:'15', title:'Capstone: AI Leadership Case', desc:'Design a complete AI transformation plan for a real-world scenario. Peer-reviewed.' },
  { num:'16', title:'Certification & Next Steps', desc:'Complete the AIQ Leadership Assessment and receive your verified AIQ credential.' },
];
---

<Layout
  title="AI~Leadership — AIQ Course Track"
  description="Lead AI transformation at scale. Drive strategy, build culture, and position yourself at the frontier of the field. 8 hours, 16 modules, Tiers 6–8."
>

<nav class="p-nav">
  <div class="p-nav-inner">
    <a href={`${base}/`} class="p-nav-logo" aria-label="AIQ Home">
      <svg width="60" height="24" viewBox="0 0 72 28" fill="none">
        <text x="0" y="22" font-family="'Space Grotesk',sans-serif" font-size="22" font-weight="800" fill="url(#ln1)">AIQ</text>
        <path d="M2 26 Q18 21 36 26 Q54 21 70 26" stroke="url(#ln1)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
        <defs><linearGradient id="ln1" x1="0" y1="0" x2="72" y2="0" gradientUnits="userSpaceOnUse"><stop stop-color="#00CFFF"/><stop offset="1" stop-color="#7C3AED"/></linearGradient></defs>
      </svg>
    </a>
    <a href={`${base}/assessment`} class="btn-primary p-nav-cta">Take the Assessment →</a>
  </div>
</nav>

<section class="course-hero grid-bg">
  <div class="glow-blob" style="width:600px;height:500px;background:var(--violet);top:-200px;right:-150px;opacity:0.15;"></div>
  <div class="glow-blob" style="width:400px;height:400px;background:var(--cyan);bottom:-100px;left:-100px;opacity:0.08;"></div>
  <div class="container">
    <div class="course-hero-inner">
      <div>
        <div class="tier-badge reveal">Tiers 6 – 8</div>
        <h1 class="course-h1 reveal reveal-delay-1">AI<span class="tilde">~</span>Leadership</h1>
        <p class="course-sub reveal reveal-delay-2">
          The highest tier of the AIQ curriculum. For those who don't just use AI — but shape how teams, organisations, and industries adopt it. Drive transformation at scale.
        </p>
        <div class="course-meta reveal reveal-delay-3">
          <span class="meta-pill">8 hours</span>
          <span class="meta-pill">16 modules</span>
          <span class="meta-pill">Tiers 6–8</span>
          <span class="meta-pill">Strategist → Pioneer</span>
        </div>
        <div class="course-btns reveal reveal-delay-4">
          <a href={NOTION_URL} class="btn-primary btn-lg" target="_blank" rel="noopener">
            Enrol in AI~Leadership →
          </a>
          <a href={`${base}/assessment`} class="btn-secondary btn-lg">Verify Your Tier</a>
        </div>
      </div>
      <div class="course-badge-wrap reveal">
        <div class="course-badge glass">
          <div class="cb-label">COURSE TRACK</div>
          <div class="cb-name gradient-text">Leadership</div>
          <div class="cb-tiers">Tier 6 → Tier 8</div>
          <div class="cb-divider"></div>
          <div class="cb-stat"><span>16</span> Modules</div>
          <div class="cb-stat"><span>8</span> Hours</div>
          <div class="cb-stat"><span>1</span> Certificate</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="p-section">
  <div class="container">
    <div class="p-section-head reveal">
      <div class="chip">Who This Is For</div>
      <h2 class="section-title">This is the right track if…</h2>
    </div>
    <div class="for-grid">
      {[
        'You lead a team, division, or organisation navigating AI',
        'You\'re responsible for AI strategy, not just AI usage',
        'You want to build AI-capable culture, not just skill individual contributors',
        'You need governance frameworks, not just prompt techniques',
        'Your AIQ score placed you at Tier 6, 7, or 8',
        'You completed AI~Workflows and are ready for strategic scope',
      ].map(item => (
        <div class="for-item glass reveal"><span class="for-check">✓</span><span>{item}</span></div>
      ))}
    </div>
  </div>
</section>

<section class="p-section modules-section">
  <div class="container">
    <div class="p-section-head reveal">
      <div class="chip">16 Modules</div>
      <h2 class="section-title">The leadership curriculum.</h2>
    </div>
    <div class="modules-grid">
      {modules.map((m, i) => (
        <div class={`module-card glass reveal ${i % 3 === 1 ? 'reveal-delay-1' : i % 3 === 2 ? 'reveal-delay-2' : ''}`}>
          <div class="mod-num">{m.num}</div>
          <div>
            <div class="mod-title">{m.title}</div>
            <div class="mod-desc">{m.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="p-section p-cta-section">
  <div class="container">
    <div class="glass cta-block reveal">
      <div class="chip" style="margin-bottom:1.5rem">The Highest Tier</div>
      <h2 class="cta-block-h2">Define the field for others.</h2>
      <p class="cta-block-sub">AI~Leadership is for the people who see further and build what comes next. Join the Sosial AI Society and claim your place at the frontier.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:2.5rem">
        <a href={NOTION_URL} class="btn-primary btn-lg" target="_blank" rel="noopener">Join & Enrol Now →</a>
        <a href={`${base}/certification`} class="btn-secondary btn-lg">View Certification →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .p-nav{position:sticky;top:0;z-index:100;background:rgba(4,7,15,0.85);backdrop-filter:blur(12px);border-bottom:1px solid rgba(0,207,255,0.08);height:60px}
  .p-nav-inner{max-width:1140px;margin:0 auto;height:100%;padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between}
  .p-nav-logo{display:flex;align-items:center;text-decoration:none}
  .p-nav-cta{font-size:0.85rem;padding:0.55rem 1.25rem}
  .course-hero{padding:6rem 1.5rem 5rem;position:relative;overflow:hidden}
  .course-hero-inner{max-width:1060px;margin:0 auto;display:grid;grid-template-columns:1fr auto;gap:4rem;align-items:center}
  @media(max-width:700px){.course-hero-inner{grid-template-columns:1fr}}
  .tier-badge{display:inline-block;padding:0.3rem 0.9rem;border-radius:999px;border:1px solid rgba(124,58,237,0.5);background:rgba(124,58,237,0.12);font-size:0.75rem;font-weight:700;letter-spacing:0.08em;color:#c084fc;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;margin-bottom:1rem}
  .course-h1{font-size:clamp(2.5rem,5vw,3.75rem);font-weight:800;font-family:'Space Grotesk',sans-serif;margin-bottom:1.25rem;line-height:1.1}
  .tilde{background:linear-gradient(135deg,#00CFFF,#7C3AED);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .course-sub{color:var(--muted);font-size:1.1rem;line-height:1.75;margin-bottom:2rem;max-width:520px}
  .course-meta{display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:2rem}
  .meta-pill{padding:0.35rem 0.85rem;border-radius:999px;border:1px solid rgba(0,207,255,0.15);background:rgba(0,207,255,0.05);font-size:0.8rem;color:var(--muted);font-family:'JetBrains Mono',monospace}
  .course-btns{display:flex;gap:1rem;flex-wrap:wrap}
  .btn-lg{padding:1rem 2.25rem;font-size:1rem}
  .course-badge-wrap{flex-shrink:0}
  .course-badge{padding:2rem;min-width:180px;text-align:center}
  .cb-label{font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);font-family:'Space Grotesk',sans-serif;margin-bottom:0.5rem}
  .cb-name{font-size:1.5rem;font-weight:800;font-family:'Space Grotesk',sans-serif;margin-bottom:0.25rem}
  .cb-tiers{font-size:0.8rem;color:var(--muted);font-family:'JetBrains Mono',monospace;margin-bottom:1.25rem}
  .cb-divider{height:1px;background:rgba(0,207,255,0.1);margin-bottom:1.25rem}
  .cb-stat{font-size:0.85rem;color:var(--muted);margin-bottom:0.4rem}
  .cb-stat span{font-family:'JetBrains Mono',monospace;font-weight:700;font-size:1.1rem;color:var(--cyan)}
  .p-section{padding:5rem 1.5rem}
  .p-section-head{margin-bottom:3rem}
  .modules-section{background:rgba(8,13,26,0.5)}
  .for-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1rem}
  .for-item{display:flex;align-items:flex-start;gap:0.75rem;padding:1.1rem 1.25rem;font-size:0.9rem;color:var(--muted)}
  .for-check{color:var(--cyan);font-weight:700;flex-shrink:0;margin-top:1px}
  .modules-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem}
  .module-card{display:flex;align-items:flex-start;gap:1rem;padding:1.25rem 1.5rem}
  .mod-num{font-family:'JetBrains Mono',monospace;font-size:0.78rem;font-weight:700;color:var(--cyan);opacity:0.7;flex-shrink:0;margin-top:2px}
  .mod-title{font-family:'Space Grotesk',sans-serif;font-size:0.95rem;font-weight:700;margin-bottom:0.35rem}
  .mod-desc{font-size:0.83rem;color:var(--muted);line-height:1.5}
  .p-cta-section{padding:4rem 1.5rem 7rem}
  .cta-block{max-width:680px;margin:0 auto;padding:3.5rem;text-align:center;position:relative;overflow:hidden}
  .cta-block-h2{font-family:'Space Grotesk',sans-serif;font-size:clamp(1.5rem,3.5vw,2.25rem);font-weight:800;margin-bottom:1rem}
  .cta-block-sub{color:var(--muted);font-size:1rem;line-height:1.7;max-width:480px;margin:0 auto}
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>

</Layout>
