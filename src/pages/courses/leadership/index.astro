---
import Layout from '../../../layouts/Layout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import { leadership } from '../../../data/leadership-course';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const FORUM_URL = `${base}/forum`;

const tier7 = leadership.filter(l => l.tier === 7);
const tier8 = leadership.filter(l => l.tier === 8);
const tier9 = leadership.filter(l => l.tier === 9);
const firstLesson = leadership[0];
---

<Layout
  title="AI~Leadership — AIQ Course Track"
  description="Lead AI transformation at scale. Drive strategy, build AI-capable culture, and operate at the frontier of the field. 20 modules, Tiers 7–9."
>

<SiteNav active="society" />

<!-- HERO -->
<section class="course-hero grid-bg">
  <div class="glow-blob" style="width:600px;height:500px;background:var(--violet);top:-200px;right:-150px;opacity:0.16;"></div>
  <div class="glow-blob" style="width:300px;height:300px;background:#f59e0b;bottom:-100px;left:-50px;opacity:0.06;"></div>
  <div class="container">
    <div class="course-hero-inner">
      <div>
        <div class="tier-badge reveal">Tiers 7 – 9</div>
        <h1 class="course-h1 reveal reveal-delay-1">AI<span class="tilde">~</span>Leadership</h1>
        <p class="course-sub reveal reveal-delay-2">
          The highest tier of the AIQ curriculum. For those who don't just use AI — but shape how teams, organisations, and industries adopt it. Drive transformation at scale. Operate at the frontier.
        </p>
        <div class="course-meta reveal reveal-delay-3">
          <span class="meta-pill">~12 hours</span>
          <span class="meta-pill">20 modules</span>
          <span class="meta-pill">Tiers 7–9</span>
          <span class="meta-pill">Strategist → Pioneer</span>
        </div>
        <div class="course-btns reveal reveal-delay-4">
          <a href={`${base}/courses/leadership/${firstLesson.slug}`} class="btn-primary btn-lg">
            Start Module 01
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href={`${base}/courses/workflows`} class="btn-secondary btn-lg">← Start with Workflows</a>
        </div>
      </div>
      <div class="course-badge-wrap reveal">
        <div class="course-badge glass">
          <div class="cb-label">COURSE TRACK</div>
          <div class="cb-name gradient-text">Leadership</div>
          <div class="cb-tiers">Tier 7 → Tier 9</div>
          <div class="cb-divider"></div>
          <div class="cb-stat"><span>20</span> Modules</div>
          <div class="cb-stat"><span>~12</span> Hours</div>
          <div class="cb-stat"><span>1</span> Certificate</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHO THIS IS FOR -->
<section class="p-section">
  <div class="container">
    <div class="p-section-head reveal">
      <div class="chip">Who This Is For</div>
      <h2 class="section-title">You belong here if…</h2>
    </div>
    <div class="for-grid">
      {[
        'You lead a team, division, or organisation navigating AI adoption',
        'You\'re responsible for AI strategy, not just AI usage',
        'You want to build AI-capable culture, not just skill individual contributors',
        'You need governance frameworks and stakeholder navigation, not just techniques',
        'Your AIQ score placed you at Tier 7, 8, or 9',
        'You completed AI~Workflows and are ready for strategic scope',
      ].map(item => (
        <div class="for-item glass reveal"><span class="for-check">✓</span><span>{item}</span></div>
      ))}
    </div>
  </div>
</section>

<!-- MODULES -->
<section class="p-section modules-section">
  <div class="container">
    <div class="p-section-head reveal">
      <div class="chip">20 Modules · 3 Tiers</div>
      <h2 class="section-title">The complete curriculum.</h2>
      <p class="section-sub">From organisational strategy through transformational leadership to Pioneer-tier practice. Each module is a complete learning unit with concept, demo, exercise, and active recall.</p>
    </div>

    <!-- Tier 7 -->
    <div class="tier-group reveal">
      <div class="tier-group-header">
        <span class="tier-group-badge tier-7">Tier 7 — Organisational Strategy</span>
        <span class="tier-group-desc">Lead AI adoption across teams and functions</span>
      </div>
      <div class="modules-grid">
        {tier7.map((m, i) => (
          <a href={`${base}/courses/leadership/${m.slug}`} class={`module-card glass reveal ${i % 3 === 1 ? 'reveal-delay-1' : i % 3 === 2 ? 'reveal-delay-2' : ''}`}>
            <div class="mod-num">{String(m.module).padStart(2,'0')}</div>
            <div class="mod-body">
              <div class="mod-title">{m.title}</div>
              <div class="mod-desc">{m.subtitle}</div>
            </div>
            <div class="mod-meta">
              <span class="mod-duration">{m.duration}</span>
              {m.module > 1 ? (<svg width="13" height="13" viewBox="0 0 13 13" fill="none" style="flex-shrink:0;opacity:0.5"><rect x="3" y="6" width="7" height="5" rx="1.5" stroke="#6B7A99" stroke-width="1.2"/><path d="M5 6V4.5a2 2 0 0 1 3 0V6" stroke="#6B7A99" stroke-width="1.2" stroke-linecap="round"/></svg>) : (<svg class="mod-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M8 4l3 3-3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>)}
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Tier 8 -->
    <div class="tier-group reveal">
      <div class="tier-group-header">
        <span class="tier-group-badge tier-8">Tier 8 — Transformational Leadership</span>
        <span class="tier-group-desc">Drive organisation-wide AI change and culture</span>
      </div>
      <div class="modules-grid">
        {tier8.map((m, i) => (
          <a href={`${base}/courses/leadership/${m.slug}`} class={`module-card glass reveal ${i % 3 === 1 ? 'reveal-delay-1' : i % 3 === 2 ? 'reveal-delay-2' : ''}`}>
            <div class="mod-num">{String(m.module).padStart(2,'0')}</div>
            <div class="mod-body">
              <div class="mod-title">{m.title}</div>
              <div class="mod-desc">{m.subtitle}</div>
            </div>
            <div class="mod-meta">
              <span class="mod-duration">{m.duration}</span>
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" style="flex-shrink:0;opacity:0.5"><rect x="3" y="6" width="7" height="5" rx="1.5" stroke="#6B7A99" stroke-width="1.2"/><path d="M5 6V4.5a2 2 0 0 1 3 0V6" stroke="#6B7A99" stroke-width="1.2" stroke-linecap="round"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Tier 9 -->
    <div class="tier-group reveal">
      <div class="tier-group-header">
        <span class="tier-group-badge tier-9">Tier 9 — Pioneer</span>
        <span class="tier-group-desc">Define what's possible. Shape the field.</span>
      </div>
      <div class="modules-grid">
        {tier9.map((m, i) => (
          <a href={`${base}/courses/leadership/${m.slug}`} class={`module-card glass reveal ${i % 3 === 1 ? 'reveal-delay-1' : i % 3 === 2 ? 'reveal-delay-2' : ''}`}>
            <div class="mod-num">{String(m.module).padStart(2,'0')}</div>
            <div class="mod-body">
              <div class="mod-title">{m.title}</div>
              <div class="mod-desc">{m.subtitle}</div>
            </div>
            <div class="mod-meta">
              <span class="mod-duration">{m.duration}</span>
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" style="flex-shrink:0;opacity:0.5"><rect x="3" y="6" width="7" height="5" rx="1.5" stroke="#6B7A99" stroke-width="1.2"/><path d="M5 6V4.5a2 2 0 0 1 3 0V6" stroke="#6B7A99" stroke-width="1.2" stroke-linecap="round"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="p-section p-cta-section">
  <div class="container">
    <div class="glass cta-block reveal">
      <div class="chip" style="margin-bottom:1.5rem">The Highest Tier</div>
      <h2 class="cta-block-h2">Define the field for others.</h2>
      <p class="cta-block-sub">AI~Leadership is for the people who see further and build what comes next. Start Module 01 — free and open. No account needed to begin.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:2.5rem">
        <a href={`${base}/courses/leadership/${firstLesson.slug}`} class="btn-primary btn-lg">
          Start Module 01: {firstLesson.title}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href={`${base}/certification`} class="btn-secondary btn-lg">View Certification →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .p-nav{position:sticky;top:0;z-index:100;background:rgba(4,7,15,0.85);backdrop-filter:blur(12px);border-bottom:1px solid rgba(0,207,255,0.08);height:60px}
  .p-nav-inner{max-width:1140px;margin:0 auto;height:100%;padding:0 1.5rem;display:flex;align-items:center;gap:2rem}
  .p-nav-logo{display:flex;align-items:center;text-decoration:none;flex-shrink:0}
  .p-nav-links{display:flex;align-items:center;gap:1.5rem;flex:1}
  .p-nav-link{font-family:'Space Grotesk',sans-serif;font-size:0.88rem;font-weight:500;color:var(--muted);text-decoration:none;transition:color 0.2s}
  .p-nav-link:hover{color:var(--text)}
  .p-nav-link--active{color:var(--cyan)}
  .p-nav-cta{font-size:0.85rem;padding:0.55rem 1.25rem;margin-left:auto;flex-shrink:0}
  @media(max-width:768px){.p-nav-links{display:none}}

  .course-hero{padding:6rem 1.5rem 5rem;position:relative;overflow:hidden}
  .course-hero-inner{max-width:1060px;margin:0 auto;display:grid;grid-template-columns:1fr auto;gap:4rem;align-items:center}
  @media(max-width:700px){.course-hero-inner{grid-template-columns:1fr}}
  .tier-badge{display:inline-block;padding:0.3rem 0.9rem;border-radius:999px;border:1px solid rgba(245,158,11,0.4);background:rgba(245,158,11,0.1);font-size:0.75rem;font-weight:700;letter-spacing:0.08em;color:#fbbf24;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;margin-bottom:1rem}
  .course-h1{font-size:clamp(2.5rem,5vw,3.75rem);font-weight:800;font-family:'Space Grotesk',sans-serif;margin-bottom:1.25rem;line-height:1.1}
  .tilde{background:linear-gradient(135deg,#00CFFF,#7C3AED);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
  .course-sub{color:var(--muted);font-size:1.1rem;line-height:1.75;margin-bottom:2rem;max-width:520px}
  .course-meta{display:flex;flex-wrap:wrap;gap:0.5rem;margin-bottom:2rem}
  .meta-pill{padding:0.35rem 0.85rem;border-radius:999px;border:1px solid rgba(245,158,11,0.18);background:rgba(245,158,11,0.05);font-size:0.8rem;color:var(--muted);font-family:'JetBrains Mono',monospace}
  .course-btns{display:flex;gap:1rem;flex-wrap:wrap}
  .btn-lg{padding:1rem 2.25rem;font-size:1rem}
  .course-badge-wrap{flex-shrink:0}
  .course-badge{padding:2rem;min-width:180px;text-align:center}
  .cb-label{font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);font-family:'Space Grotesk',sans-serif;margin-bottom:0.5rem}
  .cb-name{font-size:1.5rem;font-weight:800;font-family:'Space Grotesk',sans-serif;margin-bottom:0.25rem}
  .cb-tiers{font-size:0.8rem;color:var(--muted);font-family:'JetBrains Mono',monospace;margin-bottom:1.25rem}
  .cb-divider{height:1px;background:rgba(245,158,11,0.12);margin-bottom:1.25rem}
  .cb-stat{font-size:0.85rem;color:var(--muted);margin-bottom:0.4rem}
  .cb-stat span{font-family:'JetBrains Mono',monospace;font-weight:700;font-size:1.1rem;color:#fbbf24}

  .p-section{padding:5rem 1.5rem}
  .p-section-head{margin-bottom:3rem}
  .section-title{font-family:'Space Grotesk',sans-serif;font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:800;margin-bottom:0.75rem}
  .section-sub{color:var(--muted);font-size:1rem;line-height:1.7;max-width:560px}
  .chip{display:inline-block;padding:0.3rem 0.9rem;border-radius:999px;border:1px solid rgba(245,158,11,0.25);background:rgba(245,158,11,0.08);font-size:0.75rem;font-weight:700;letter-spacing:0.06em;color:#fbbf24;font-family:'Space Grotesk',sans-serif;text-transform:uppercase;margin-bottom:1rem}

  .for-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1rem}
  .for-item{display:flex;align-items:flex-start;gap:0.75rem;padding:1.1rem 1.25rem;font-size:0.9rem;color:var(--muted)}
  .for-check{color:#fbbf24;font-weight:700;flex-shrink:0;margin-top:1px}

  .modules-section{background:rgba(8,13,26,0.5)}

  .tier-group{margin-bottom:3rem}
  .tier-group-header{display:flex;align-items:center;gap:1rem;margin-bottom:1.25rem;flex-wrap:wrap}
  .tier-group-badge{display:inline-block;padding:0.3rem 0.85rem;border-radius:999px;font-size:0.75rem;font-weight:700;letter-spacing:0.05em;font-family:'Space Grotesk',sans-serif}
  .tier-7{background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.25);color:#818cf8}
  .tier-8{background:rgba(168,85,247,0.08);border:1px solid rgba(168,85,247,0.25);color:#c084fc}
  .tier-9{background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.25);color:#fbbf24}
  .tier-group-desc{font-size:0.88rem;color:var(--muted)}

  .modules-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:0.85rem}
  .module-card{display:flex;align-items:flex-start;gap:1rem;padding:1.25rem 1.5rem;text-decoration:none;transition:border-color 0.2s,box-shadow 0.2s,transform 0.2s}
  .module-card:hover{border-color:rgba(245,158,11,0.3);box-shadow:0 0 20px rgba(245,158,11,0.08);transform:translateY(-2px)}
  .mod-num{font-family:'JetBrains Mono',monospace;font-size:0.72rem;font-weight:700;color:#fbbf24;opacity:0.7;flex-shrink:0;margin-top:3px}
  .mod-body{flex:1}
  .mod-title{font-family:'Space Grotesk',sans-serif;font-size:0.95rem;font-weight:700;margin-bottom:0.35rem;color:var(--text)}
  .mod-desc{font-size:0.8rem;color:var(--muted);line-height:1.5}
  .mod-meta{display:flex;align-items:center;gap:0.4rem;flex-shrink:0;margin-top:3px}
  .mod-duration{font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--muted);white-space:nowrap}
  .mod-arrow{color:rgba(107,122,153,0.4);transition:color 0.2s,transform 0.2s}
  .module-card:hover .mod-arrow{color:#fbbf24;transform:translateX(3px)}

  .p-cta-section{padding:4rem 1.5rem 7rem}
  .cta-block{max-width:680px;margin:0 auto;padding:3.5rem;text-align:center;position:relative;overflow:hidden}
  .cta-block-h2{font-family:'Space Grotesk',sans-serif;font-size:clamp(1.5rem,3.5vw,2.25rem);font-weight:800;margin-bottom:1rem}
  .cta-block-sub{color:var(--muted);font-size:1rem;line-height:1.7;max-width:480px;margin:0 auto}
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>

<SiteFooter />
</Layout>
