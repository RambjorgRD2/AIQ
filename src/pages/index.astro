    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.5;
    padding-top: 0.25rem;
  }

  /* ─── RESPONSIVE ───────────────────────────────── */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-content { max-width: 100%; }

    .hero-ctas { justify-content: center; }

    .hero-note { justify-content: center; }

