---
import Layout from '../layouts/Layout.astro';

const NOTION_FORM_URL = 'https://walnut-sea-abb.notion.site/3213f9fc4e588013bacbe0f823a2ae09?pvs=105';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const ASSESSMENT_URL = `${BASE}/assessment`;
---

<Layout title="AI~Quotient — Know Your AIQ" description="Discover your AI Quotient. Know before you Grow. The AI~Quotient assessment measures how you think, work, and lead with AI across 9 tiers.">

  <!-- ─── NAV ──────────────────────────────────────────── -->
  <nav id="nav">
    <div class="nav-inner container">
      <a href="#" class="nav-logo" aria-label="AIQ Home">
        <svg width="72" height="28" viewBox="0 0 72 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <text x="0" y="22" font-family="'Space Grotesk', sans-serif" font-size="22" font-weight="800" fill="url(#navGrad)">AIQ</text>
          <path d="M2 26 Q18 21 36 26 Q54 21 70 26" stroke="url(#navGrad)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
          <defs>
            <linearGradient id="navGrad" x1="0" y1="0" x2="72" y2="0" gradientUnits="userSpaceOnUse">
              <stop stop-color="#00CFFF"/>
              <stop offset="1" stop-color="#7C3AED"/>
            </linearGradient>
          </defs>
        </svg>
      </a>

      <ul class="nav-links">
        <li><a href="#about">About</a></li>
        <li><a href="#society">Society</a></li>
        <li><a href="#how">How It Works</a></li>
        <li><a href={ASSESSMENT_URL}>Assessment</a></li>
        <li><a href={`${BASE}/forum`}>Forum</a></li>
        <li><a href={`${BASE}/blog`}>Blog</a></li>
      </ul>

      <a href={ASSESSMENT_URL} class="btn-primary nav-cta">
        Take the Assessment
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>

      <button class="nav-hamburger" aria-label="Menu" id="hamburger">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div class="mobile-menu glass" id="mobileMenu">
    <a href="#about" class="mobile-link">About</a>
    <a href="#society" class="mobile-link">Society</a>
    <a href="#how" class="mobile-link">How It Works</a>
    <a href={ASSESSMENT_URL} class="mobile-link">Assessment</a>
    <a href={`${BASE}/forum`} class="mobile-link">Forum</a>
    <a href={`${BASE}/blog`} class="mobile-link">Blog</a>
    <a href={ASSESSMENT_URL} class="btn-primary" style="margin-top:0.5rem">Discover your AIQ</a>
  </div>

  <!-- ─── HERO ─────────────────────────────────────────── -->
  <section id="hero" class="grid-bg">
    <!-- Glow blobs -->
    <div class="glow-blob hero-glow-1"></div>
    <div class="glow-blob hero-glow-2"></div>

    <div class="container hero-inner">
      <div class="hero-content">
        <div class="chip">
          <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" fill="#00CFFF"/></svg>
          AI~Quotient
        </div>
        <p class="hero-philosophy">Know before you Grow.</p>
        <h1 class="hero-headline">
          Know Your<br />
          <span class="gradient-text">AIQ.</span>
        </h1>
        <p class="hero-sub">
          Your AI Quotient — the measure of how effectively you<br class="hero-br" />
          think, work, and lead with artificial intelligence.
        </p>
        <p class="hero-ownership">Your AIQ belongs to you — not a platform, not a company.</p>
        <div class="hero-ctas">
          <a href={ASSESSMENT_URL} class="btn-primary">
            Discover your AIQ
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href={NOTION_FORM_URL} class="btn-secondary" target="_blank" rel="noopener">
            Join the Society
          </a>
        </div>
        <p class="hero-dual-path">Discover your AIQ. <a href={NOTION_FORM_URL} target="_blank" rel="noopener">Join the Society.</a></p>
        <p class="hero-note">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M6.5 1a5.5 5.5 0 100 11A5.5 5.5 0 006.5 1zm0 5v3m0-5v1" stroke="#6B7A99" stroke-width="1.4" stroke-linecap="round"/></svg>
          Free to join &mdash; no credit card required
        </p>
      </div>

      <!-- Score ring -->
      <div class="hero-visual animate-float">
        <div class="score-ring-wrap">
          <svg class="score-ring" viewBox="0 0 200 200" width="240" height="240">
            <!-- Outer decorative ring -->
            <circle cx="100" cy="100" r="90" stroke="rgba(0,207,255,0.06)" stroke-width="1" fill="none"/>
            <!-- Track -->
            <circle
              cx="100" cy="100" r="82"
              stroke="rgba(0,207,255,0.1)"
              stroke-width="12"
              fill="none"
              stroke-linecap="round"
            />
            <!-- Arc — animated -->
            <circle
              id="scoreArc"
              cx="100" cy="100" r="82"
              stroke="url(#arcGrad)"
              stroke-width="12"
              fill="none"
              stroke-linecap="round"
              stroke-dasharray="515"
              stroke-dashoffset="515"
              transform="rotate(-90 100 100)"
            />
            <!-- Inner glow circle -->
            <circle cx="100" cy="100" r="66" fill="rgba(0,207,255,0.03)" stroke="rgba(0,207,255,0.06)" stroke-width="1"/>

            <!-- Score number -->
            <text x="100" y="90" text-anchor="middle" font-family="'JetBrains Mono', monospace" font-size="36" font-weight="700" fill="#E8F0FF" id="scoreNum">0</text>
            <text x="100" y="112" text-anchor="middle" font-family="'Space Grotesk', sans-serif" font-size="11" font-weight="500" fill="#6B7A99" letter-spacing="2">AI QUOTIENT</text>

            <!-- Tier badge -->
            <rect x="64" y="120" width="72" height="22" rx="11" fill="rgba(0,207,255,0.1)" stroke="rgba(0,207,255,0.25)" stroke-width="1"/>
            <text x="100" y="135" text-anchor="middle" font-family="'Space Grotesk', sans-serif" font-size="9" font-weight="700" fill="#00CFFF" letter-spacing="1.5">ADVANCED</text>

            <defs>
              <linearGradient id="arcGrad" x1="0" y1="0" x2="200" y2="0" gradientUnits="userSpaceOnUse">
                <stop stop-color="#00CFFF"/>
                <stop offset="1" stop-color="#7C3AED"/>
              </linearGradient>
            </defs>
          </svg>

          <!-- Orbiting dots -->
          <div class="orbit-dot orbit-dot-1"></div>
          <div class="orbit-dot orbit-dot-2"></div>
          <div class="orbit-dot orbit-dot-3"></div>
        </div>

        <!-- Stat cards below ring -->
        <div class="hero-stats">
          <div class="stat-pill glass">
            <span class="stat-num gradient-text">3</span>
            <span class="stat-label">Dimensions</span>
          </div>
          <div class="stat-pill glass">
            <span class="stat-num gradient-text">9</span>
            <span class="stat-label">Tiers</span>
          </div>
          <div class="stat-pill glass">
            <span class="stat-num gradient-text">Free</span>
            <span class="stat-label">Assessment</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-hint">
      <div class="scroll-mouse"></div>
      <span>Scroll to explore</span>
    </div>
  </section>

  <!-- ─── ABOUT AIQ ─────────────────────────────────────── -->
  <section id="about">
    <div class="container">
      <div class="section-header reveal">
        <div class="chip">What is AIQ?</div>
        <h2 class="section-title">
          Intelligence, <span class="gradient-text">Measured.</span>
        </h2>
        <p class="section-sub">
          AIQ is your AI Quotient — a composite measure of how fluently you think, apply, and lead with artificial intelligence across work, strategy, and life.
        </p>
        <div class="philosophy-callout reveal">
          <span class="philosophy-tilde">~</span>
          <span class="philosophy-text">Know before you Grow. Measure where you stand before choosing where to go.</span>
        </div>
      </div>

      <div class="pillars">
        <div class="pillar glass reveal reveal-delay-1">
          <div class="pillar-icon" style="--c:#00CFFF">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z" fill="currentColor" opacity=".2"/><path d="M9.5 3.5a8.5 8.5 0 100 17 8.5 8.5 0 000-17z" stroke="#00CFFF" stroke-width="1.5" fill="none"/><path d="M7 12h5m0 0l-2-2m2 2l-2 2" stroke="#00CFFF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="15" cy="9" r="1.5" fill="#00CFFF"/></svg>
          </div>
          <h3>Think</h3>
          <p>How clearly you reason about AI — its possibilities, limits, and implications.</p>
        </div>

        <div class="pillar glass reveal reveal-delay-2">
          <div class="pillar-icon" style="--c:#A855F7">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1.5" stroke="#A855F7" stroke-width="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5" stroke="#A855F7" stroke-width="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5" stroke="#A855F7" stroke-width="1.5"/><path d="M14 17.5h7M17.5 14v7" stroke="#A855F7" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <h3>Apply</h3>
          <p>How effectively you use AI tools, workflows, and models to get real-world results.</p>
        </div>

        <div class="pillar glass reveal reveal-delay-3">
          <div class="pillar-icon" style="--c:#EC4899">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 3l2.5 5 5.5.8-4 3.9.9 5.5L12 15.7l-4.9 2.5.9-5.5L4 8.8l5.5-.8L12 3z" stroke="#EC4899" stroke-width="1.5" stroke-linejoin="round" fill="none"/></svg>
          </div>
          <h3>Lead</h3>
          <p>How strategically you guide teams, decisions, and organizations through an AI-driven world.</p>
        </div>
      </div>

      <!-- Score scale -->
      <div class="score-scale reveal">
        <p class="score-scale-label">AIQ Score Tiers</p>
        <div class="scale-bar">
          <div class="scale-fill"></div>
          <div class="scale-markers">
            <span class="scale-mark" style="left:0%">0</span>
            <span class="scale-mark" style="left:22%">Aware</span>
            <span class="scale-mark" style="left:44%">Practitioner</span>
            <span class="scale-mark" style="left:67%">Advanced</span>
            <span class="scale-mark" style="left:89%">Pioneer</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SOCIETY ───────────────────────────────────────── -->
  <section id="society" class="society-section">
    <div class="glow-blob society-glow"></div>
    <div class="container">
      <div class="society-grid">
        <div class="society-left reveal">
          <div class="chip">Members Community</div>
          <h2 class="section-title">
            The <span class="gradient-text-warm">Sosial AI</span><br />Society
          </h2>
          <p class="section-sub" style="margin-bottom:2rem">
            A curated community for people serious about mastering AI. Courses, live sessions, peer learning, and a path to real AI fluency — not hype.
          </p>
          <ul class="society-perks">
            <li>
              <div class="perk-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8l3.5 3.5L13 4.5" stroke="#00CFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
              Structured learning tracks by AIQ tier
            </li>
            <li>
              <div class="perk-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8l3.5 3.5L13 4.5" stroke="#00CFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
              Live workshops & expert masterclasses
            </li>
            <li>
              <div class="perk-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8l3.5 3.5L13 4.5" stroke="#00CFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
              AI tools, prompt libraries & playbooks
            </li>
            <li>
              <div class="perk-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8l3.5 3.5L13 4.5" stroke="#00CFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
              Members-only community & accountability
            </li>
            <li>
              <div class="perk-icon"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8l3.5 3.5L13 4.5" stroke="#00CFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
              AIQ certification upon completion
            </li>
          </ul>
          <a href={NOTION_FORM_URL} class="btn-primary" target="_blank" rel="noopener">
            Join the Society
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="society-right reveal reveal-delay-2">
          <div class="course-card glass">
            <div class="course-card-header">
              <span class="course-tag">Foundations</span>
              <span class="course-level">Aware → Practitioner</span>
            </div>
            <h4>AI~Foundations</h4>
            <p>Build your mental model of AI — what it is, how it thinks, and where to start.</p>
            <div class="course-meta">
              <span><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><circle cx="6.5" cy="6.5" r="5.5" stroke="#6B7A99" stroke-width="1.2"/><path d="M6.5 4v3l2 1.5" stroke="#6B7A99" stroke-width="1.2" stroke-linecap="round"/></svg> 6 hrs</span>
              <span><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M2 10l3-3 2 2 4-5" stroke="#6B7A99" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg> 12 modules</span>
            </div>
          </div>

          <div class="course-card glass">
            <div class="course-card-header">
              <span class="course-tag" style="background:rgba(168,85,247,0.1);border-color:rgba(168,85,247,0.3);color:#A855F7">Advanced</span>
              <span class="course-level">Practitioner → Advanced</span>
            </div>
            <h4>AI~Workflows</h4>
            <p>Deploy AI into your actual work — automation, prompting, integrations, and systems thinking.</p>
            <div class="course-meta">
              <span><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><circle cx="6.5" cy="6.5" r="5.5" stroke="#6B7A99" stroke-width="1.2"/><path d="M6.5 4v3l2 1.5" stroke="#6B7A99" stroke-width="1.2" stroke-linecap="round"/></svg> 10 hrs</span>
              <span><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M2 10l3-3 2 2 4-5" stroke="#6B7A99" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg> 20 modules</span>
            </div>
          </div>

          <div class="course-card glass">
            <div class="course-card-header">
              <span class="course-tag" style="background:rgba(236,72,153,0.1);border-color:rgba(236,72,153,0.3);color:#EC4899">Pioneer</span>
              <span class="course-level">Strategist → Pioneer</span>
            </div>
            <h4>AI~Leadership</h4>
            <p>Lead AI strategy, change management, and organizational transformation.</p>
            <div class="course-meta">
              <span><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><circle cx="6.5" cy="6.5" r="5.5" stroke="#6B7A99" stroke-width="1.2"/><path d="M6.5 4v3l2 1.5" stroke="#6B7A99" stroke-width="1.2" stroke-linecap="round"/></svg> 8 hrs</span>
              <span><svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M2 10l3-3 2 2 4-5" stroke="#6B7A99" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg> 16 modules</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FEATURES ──────────────────────────────────────── -->
  <section id="features">
    <div class="container">
      <div class="section-header reveal" style="text-align:center;margin:0 auto 3.5rem">
        <div class="chip" style="justify-content:center">Everything included</div>
        <h2 class="section-title">Built for serious AI learners</h2>
        <p class="section-sub" style="margin:0 auto">Everything you need to go from curious to capable — and from capable to leading.</p>
      </div>

      <div class="features-grid">
        <div class="feature glass reveal reveal-delay-1">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><circle cx="11" cy="11" r="9" stroke="url(#fg1)" stroke-width="1.5"/><path d="M7 11l3 3 5-5" stroke="url(#fg1)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><defs><linearGradient id="fg1" x1="2" y1="2" x2="20" y2="20" gradientUnits="userSpaceOnUse"><stop stop-color="#00CFFF"/><stop offset="1" stop-color="#7C3AED"/></linearGradient></defs></svg>
          </div>
          <h3>AIQ Assessment</h3>
          <p>Get a precise baseline score across Think, Apply, and Lead dimensions. Know exactly where you stand.</p>
        </div>

        <div class="feature glass reveal reveal-delay-2">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><rect x="3" y="3" width="16" height="16" rx="3" stroke="url(#fg2)" stroke-width="1.5"/><path d="M7 8h8M7 11h5" stroke="url(#fg2)" stroke-width="1.5" stroke-linecap="round"/><defs><linearGradient id="fg2" x1="3" y1="3" x2="19" y2="19" gradientUnits="userSpaceOnUse"><stop stop-color="#00CFFF"/><stop offset="1" stop-color="#A855F7"/></linearGradient></defs></svg>
          </div>
          <h3>Structured Courses</h3>
          <p>Tier-based learning tracks designed to move you from where you are to where you want to be.</p>
        </div>

        <div class="feature glass reveal reveal-delay-3">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M4 16c0-2.8 2.2-5 5-5h4c2.8 0 5 2.2 5 5" stroke="url(#fg3)" stroke-width="1.5" stroke-linecap="round"/><circle cx="11" cy="8" r="3" stroke="url(#fg3)" stroke-width="1.5"/><defs><linearGradient id="fg3" x1="4" y1="3" x2="18" y2="19" gradientUnits="userSpaceOnUse"><stop stop-color="#A855F7"/><stop offset="1" stop-color="#EC4899"/></linearGradient></defs></svg>
          </div>
          <h3>Members Community</h3>
          <p>Connect with peers, share wins, get feedback, and grow alongside other AI-fluent professionals.</p>
        </div>

        <div class="feature glass reveal reveal-delay-4">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M3 5h16M3 11h10M3 17h13" stroke="url(#fg4)" stroke-width="1.5" stroke-linecap="round"/><circle cx="17" cy="17" r="3" fill="none" stroke="url(#fg4)" stroke-width="1.5"/><defs><linearGradient id="fg4" x1="3" y1="5" x2="20" y2="17" gradientUnits="userSpaceOnUse"><stop stop-color="#00CFFF"/><stop offset="1" stop-color="#EC4899"/></linearGradient></defs></svg>
          </div>
          <h3>Resources & Playbooks</h3>
          <p>Curated prompt libraries, AI workflow templates, and tool guides — ready to use immediately.</p>
        </div>

        <div class="feature glass reveal reveal-delay-3">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M11 3l2 6h6l-5 3.5 2 6L11 15l-5 3.5 2-6L3 9h6l2-6z" stroke="url(#fg5)" stroke-width="1.5" stroke-linejoin="round" fill="none"/><defs><linearGradient id="fg5" x1="3" y1="3" x2="19" y2="19" gradientUnits="userSpaceOnUse"><stop stop-color="#00CFFF"/><stop offset="1" stop-color="#7C3AED"/></linearGradient></defs></svg>
          </div>
          <h3>Live Sessions</h3>
          <p>Regular workshops, office hours, and expert masterclasses you can join live or watch on demand.</p>
        </div>

        <div class="feature glass reveal reveal-delay-4">
          <div class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><rect x="4" y="13" width="14" height="7" rx="2" stroke="url(#fg6)" stroke-width="1.5"/><path d="M8 13V9a3 3 0 016 0v4" stroke="url(#fg6)" stroke-width="1.5" stroke-linecap="round"/><circle cx="11" cy="17" r="1.2" fill="url(#fg6)"/><defs><linearGradient id="fg6" x1="4" y1="4" x2="18" y2="20" gradientUnits="userSpaceOnUse"><stop stop-color="#A855F7"/><stop offset="1" stop-color="#00CFFF"/></linearGradient></defs></svg>
          </div>
          <h3>AIQ Certification</h3>
          <p>Earn your verified AIQ certificate to showcase your AI fluency to employers, clients, and teams.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── HOW IT WORKS ──────────────────────────────────── -->
  <section id="how" class="how-section grid-bg">
    <div class="glow-blob how-glow"></div>
    <div class="container">
      <div class="section-header reveal" style="text-align:center;margin:0 auto 4rem">
        <div class="chip" style="justify-content:center">The Process</div>
        <h2 class="section-title">Three steps to AI fluency</h2>
        <p class="section-sub" style="margin:0 auto">Simple, structured, and designed to create lasting results — not just surface knowledge.</p>
      </div>

      <div class="steps">
        <div class="step reveal reveal-delay-1">
          <div class="step-number">01</div>
          <div class="step-connector"></div>
          <div class="step-content glass">
            <div class="step-icon">
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="11" stroke="url(#sg1)" stroke-width="1.5"/><text x="14" y="19" text-anchor="middle" font-family="'JetBrains Mono'" font-size="13" font-weight="700" fill="url(#sg1)">?</text><defs><linearGradient id="sg1" x1="3" y1="3" x2="25" y2="25" gradientUnits="userSpaceOnUse"><stop stop-color="#00CFFF"/><stop offset="1" stop-color="#7C3AED"/></linearGradient></defs></svg>
            </div>
            <h3>Take the AIQ Assessment</h3>
            <p>Answer a curated set of questions that measure your AI thinking, application, and leadership. Get your score in minutes.</p>
          </div>
        </div>

        <div class="step reveal reveal-delay-2">
          <div class="step-number">02</div>
          <div class="step-connector"></div>
          <div class="step-content glass">
            <div class="step-icon">
