</style>

<!-- ─── SCRIPTS ─────────────────────────────────────────────── -->
<script>
  // Sticky nav on scroll
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) nav?.classList.add('scrolled');
    else nav?.classList.remove('scrolled');
  }, { passive: true });

  // Mobile menu toggle
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => mobileMenu.classList.remove('open'));
  });

  // Scroll reveal
  const reveals = document.querySelectorAll<HTMLElement>('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('visible');
      }
    });
  }, { threshold: 0.12 });
  reveals.forEach(el => observer.observe(el));

  // Score ring animation
  const arc = document.getElementById('scoreArc') as SVGCircleElement | null;
  const numEl = document.getElementById('scoreNum');
  const TARGET_SCORE = 71;
  const MAX_SCORE = 100;
  const CIRCUMFERENCE = 515;
  const targetOffset = CIRCUMFERENCE - (TARGET_SCORE / MAX_SCORE) * CIRCUMFERENCE;

  function animateScore() {
    if (!arc || !numEl) return;
    const startTime = performance.now();
    const duration = 1800;

    function step(now: number) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic

      // Arc
      const currentOffset = CIRCUMFERENCE - eased * (CIRCUMFERENCE - targetOffset);
      arc.style.strokeDashoffset = String(currentOffset);

      // Number counter
      const currentScore = Math.round(eased * TARGET_SCORE);
      numEl.textContent = String(currentScore);

      if (progress < 1) requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  // Trigger animation when hero visual enters viewport
  const heroVisual = document.querySelector('.hero-visual');
  const heroObs = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      setTimeout(animateScore, 400);
      heroObs.disconnect();
    }
  }, { threshold: 0.3 });
  if (heroVisual) heroObs.observe(heroVisual);
</script>
