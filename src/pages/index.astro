    border: 1.5px solid rgba(107, 122, 153, 0.4);
    border-radius: 11px;
    position: relative;
  }

  .scroll-mouse::after {
    content: '';
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 3px;
    height: 6px;
    background: var(--cyan);
    border-radius: 2px;
    animation: scrollDot 2s ease-in-out infinite;
