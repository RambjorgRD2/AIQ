---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Your AI~Quotient Results"
  description="Your personalised AI~Quotient score across Think, Apply, and Lead dimensions. Know before you Grow."
>

<!-- NAV -->
<nav class="r-nav">
  <div class="r-nav-inner">
    <a href={`${import.meta.env.BASE_URL}`} class="r-nav-logo" aria-label="AIQ Home">
      <svg width="60" height="24" viewBox="0 0 72 28" fill="none">
        <text x="0" y="22" font-family="'Space Grotesk',sans-serif" font-size="22" font-weight="800" fill="url(#rg1)">AIQ</text>
        <path d="M2 26 Q18 21 36 26 Q54 21 70 26" stroke="url(#rg1)" stroke-width="1.8" stroke-linecap="round" fill="none"/>
        <defs>
          <linearGradient id="rg1" x1="0" y1="0" x2="72" y2="0" gradientUnits="userSpaceOnUse">
            <stop stop-color="#00CFFF"/><stop offset="1" stop-color="#7C3AED"/>
          </linearGradient>
        </defs>
      </svg>
    </a>
    <a id="btn-retake" href="#" class="btn-secondary r-nav-retake">Retake Assessment</a>
  </div>
</nav>

<!-- NO RESULT STATE (hidden by JS when result exists) -->
<div id="no-result" style="display:none">
  <div class="empty-state">
    <p class="empty-icon">—</p>
    <h2>No result found</h2>
    <p class="empty-sub">Take the AIQ Assessment to discover your score.</p>
    <a id="btn-take" href="#" class="btn-primary" style="margin-top:2rem">
      Take the Assessment →
    </a>
  </div>
</div>

<!-- RESULTS (hidden until JS populates) -->
<div id="results-content" style="display:none">

  <!-- ── HERO: SCORE ────────────────────────────────── -->
  <section class="r-hero">
    <div class="container">
      <div class="r-hero-inner">

        <!-- Score ring -->
        <div class="score-ring-wrap">
          <svg class="score-ring" width="200" height="200" viewBox="0 0 200 200">
            <circle cx="100" cy="100" r="82" fill="none" stroke="rgba(0,207,255,0.1)" stroke-width="8"/>
            <circle id="score-arc" cx="100" cy="100" r="82"
              fill="none" stroke="url(#scoreGrad)" stroke-width="8"
              stroke-linecap="round" stroke-dasharray="515" stroke-dashoffset="515"
              transform="rotate(-90 100 100)"/>
            <defs>
              <linearGradient id="scoreGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#00CFFF"/>
                <stop offset="100%" stop-color="#7C3AED"/>
              </linearGradient>
            </defs>
            <text id="score-number" x="100" y="95" text-anchor="middle"
              font-family="'JetBrains Mono',monospace" font-size="44" font-weight="700" fill="#E8F0FF">0</text>
            <text x="100" y="118" text-anchor="middle"
              font-family="'Space Grotesk',sans-serif" font-size="11" font-weight="600"
              fill="#6B7A99" letter-spacing="2">AIQ SCORE</text>
          </svg>
        </div>

        <!-- Tier + context -->
        <div class="r-hero-text">
          <div class="chip" style="margin-bottom:1rem">Your Result</div>
          <h1 class="r-score-headline">
            Tier <span id="tier-num" class="gradient-text">—</span> —
            <span id="tier-label" class="gradient-text">—</span>
          </h1>
          <p id="tier-desc" class="r-tier-desc"></p>

          <!-- Dimension pills -->
          <div class="dim-pills">
            <div class="dim-pill">
              <span class="dp-label">THINK</span>
              <span id="score-think" class="dp-val">—</span>
            </div>
            <div class="dim-pill">
              <span class="dp-label">APPLY</span>
              <span id="score-apply" class="dp-val">—</span>
            </div>
            <div class="dim-pill">
              <span class="dp-label">LEAD</span>
              <span id="score-lead" class="dp-val">—</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── TIER IDENTITY CARD ──────────────────────────── -->
  <section class="r-section r-tier-id-section">
    <div class="container">
      <div class="tier-id-card">
        <div class="tier-id-bg"></div>
        <div class="tier-id-inner">
          <div class="tier-id-top">
            <span class="tier-id-brand">AI~Quotient</span>
            <span class="tier-id-score-label">Score: <span id="tid-score" class="tier-id-score-val">—</span></span>
          </div>
          <div class="tier-id-main">
            <span class="tier-id-you">You are a</span>
            <span id="tid-label" class="tier-id-name gradient-text">—</span>
          </div>
          <div class="tier-id-dims">
            <span>Think <span id="tid-think" class="tid-dim-val">—</span></span>
            <span class="tid-sep">·</span>
            <span>Apply <span id="tid-apply" class="tid-dim-val">—</span></span>
            <span class="tid-sep">·</span>
            <span>Lead <span id="tid-lead" class="tid-dim-val">—</span></span>
          </div>
          <div class="tier-id-footer">
            <span class="tier-id-url">rambjorgrd2.github.io/AIQ</span>
            <span class="tier-id-tagline">Know before you Grow.</span>
          </div>
        </div>
      </div>
      <p class="tier-id-hint">Screenshot this card to share your tier.</p>
    </div>
  </section>

  <!-- ── RADAR CHART ────────────────────────────────── -->
  <section class="r-section">
    <div class="container r-two-col">

      <div class="glass r-card">
        <div class="r-card-label">DIMENSION BREAKDOWN</div>
        <div class="radar-wrap">
          <canvas id="radar-chart" width="300" height="300"></canvas>
        </div>
        <div class="dim-bars">
          <div class="dim-bar-row">
            <span class="dbr-label">Think</span>
            <div class="dbr-track"><div id="bar-think" class="dbr-fill dbr-think"></div></div>
            <span id="dbr-think-val" class="dbr-val">—</span>
          </div>
          <div class="dim-bar-row">
            <span class="dbr-label">Apply</span>
            <div class="dbr-track"><div id="bar-apply" class="dbr-fill dbr-apply"></div></div>
            <span id="dbr-apply-val" class="dbr-val">—</span>
          </div>
          <div class="dim-bar-row">
            <span class="dbr-label">Lead</span>
            <div class="dbr-track"><div id="bar-lead" class="dbr-fill dbr-lead"></div></div>
            <span id="dbr-lead-val" class="dbr-val">—</span>
          </div>
        </div>
      </div>

      <div class="r-right-col">

        <!-- Insight card -->
        <div class="glass r-card r-insight-card">
          <div class="r-card-label">YOUR #1 INSIGHT</div>
          <p id="insight-text" class="insight-text"></p>
        </div>

        <!-- Course recommendation -->
        <div class="glass r-card r-course-card">
          <div class="r-card-label">RECOMMENDED NEXT STEP</div>
          <div id="course-rec" class="course-rec"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── SHARE ──────────────────────────────────────── -->
  <section class="r-section r-share-section">
    <div class="container">
      <div class="share-inner">
        <p class="share-label">Share your AIQ score</p>
        <div class="share-btns">
          <button id="share-linkedin" class="share-btn share-li">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </button>
          <button id="share-x" class="share-btn share-x">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.629 5.905-5.629zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Share on X
          </button>
          <button id="share-copy" class="share-btn share-copy">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <span id="copy-label">Copy Score</span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ── RETAKE CALLOUT ────────────────────────────── -->
  <section class="r-section r-retake-section">
    <div class="container">
      <div class="retake-band glass">
        <div class="retake-icon">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 14a10 10 0 1 0 1.5-5.3" stroke="url(#retGrad)" stroke-width="1.8" stroke-linecap="round"/><path d="M4 5v5h5" stroke="url(#retGrad)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><defs><linearGradient id="retGrad" x1="2" y1="2" x2="26" y2="26" gradientUnits="userSpaceOnUse"><stop stop-color="#00CFFF"/><stop offset="1" stop-color="#7C3AED"/></linearGradient></defs></svg>
        </div>
        <div class="retake-text">
          <strong>Retake in 90 days. Track your growth.</strong>
          <span>Your AIQ is a live measure — not a one-time label. As you learn and apply, it grows.</span>
        </div>
        <a id="btn-retake-band" href="#" class="btn-secondary retake-cta">Retake Assessment</a>
      </div>
    </div>
  </section>

  <!-- ── SOCIETY CTA ────────────────────────────────── -->
  <section class="r-section r-cta-section">
    <div class="container">
      <div class="glass r-cta-card">
        <!-- Glow -->
        <div class="glow-blob" style="width:300px;height:300px;background:var(--cyan);top:-100px;left:-100px;opacity:0.08"></div>
        <div class="glow-blob" style="width:250px;height:250px;background:var(--violet);bottom:-80px;right:-60px;opacity:0.1"></div>

        <div class="chip" style="margin-bottom:1.5rem">Sosial AI Society</div>
        <h2 class="cta-h2">Unlock your full AIQ profile.</h2>
        <p class="cta-sub">Join the Sosial AI Society for your complete learning track, community access, and your verified AIQ certificate.</p>

        <div class="cta-features">
          <div class="cta-feat">
            <span class="feat-icon">✓</span>
            <span>Full personalised learning track</span>
          </div>
          <div class="cta-feat">
            <span class="feat-icon">✓</span>
            <span>Live sessions & community</span>
          </div>
          <div class="cta-feat">
            <span class="feat-icon">✓</span>
            <span>Verified AIQ Certificate</span>
          </div>
          <div class="cta-feat">
            <span class="feat-icon">✓</span>
            <span>Retake every 90 days to track growth</span>
          </div>
        </div>

        <div class="cta-btns">
          <a id="btn-join-society" href="#" class="btn-primary btn-lg">
            Join the Society
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a id="btn-view-course" href="#" class="btn-secondary btn-lg">View Your Course Track</a>
        </div>
      </div>
    </div>
  </section>

</div><!-- /results-content -->

<style>
  /* ── NAV ──────────────────────────────────────────── */
  .r-nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(4,7,15,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,207,255,0.08);
    height: 60px;
  }
  .r-nav-inner {
    max-width: 1140px; margin: 0 auto; height: 100%;
    padding: 0 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
  }
  .r-nav-logo { display: flex; align-items: center; text-decoration: none; }
  .r-nav-retake { font-size: 0.85rem; padding: 0.5rem 1.25rem; }

  /* ── EMPTY STATE ──────────────────────────────────── */
  .empty-state {
    max-width: 420px; margin: 8rem auto; text-align: center; padding: 0 1.5rem;
  }
  .empty-icon { font-size: 3rem; color: var(--muted); margin-bottom: 1rem; }
  .empty-state h2 {
    font-family: 'Space Grotesk', sans-serif; font-size: 1.75rem; margin-bottom: 0.75rem;
  }
  .empty-sub { color: var(--muted); }

  /* ── HERO ─────────────────────────────────────────── */
  .r-hero {
    padding: 5rem 1.5rem 3rem;
    background: radial-gradient(ellipse 800px 400px at 50% 0%, rgba(0,207,255,0.05) 0%, transparent 70%);
  }
  .r-hero-inner {
    max-width: 900px; margin: 0 auto;
    display: flex; align-items: center; gap: 4rem; flex-wrap: wrap;
  }
  .score-ring-wrap { flex-shrink: 0; }
  .score-ring { display: block; }
  .r-hero-text { flex: 1; min-width: 260px; }
  .r-score-headline {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    font-weight: 800; margin-bottom: 1rem; line-height: 1.2;
  }
  .r-tier-desc {
    color: var(--muted); font-size: 1.05rem; line-height: 1.65;
    margin-bottom: 1.75rem; max-width: 440px;
  }
  .dim-pills { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .dim-pill {
    display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
    padding: 0.65rem 1rem; border-radius: 10px;
    border: 1px solid rgba(0,207,255,0.2); background: rgba(0,207,255,0.05);
    min-width: 72px;
  }
  .dp-label {
    font-family: 'Space Grotesk', sans-serif; font-size: 0.65rem;
    font-weight: 700; letter-spacing: 0.1em; color: var(--muted);
  }
  .dp-val {
    font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; font-weight: 700;
    background: linear-gradient(135deg, #00CFFF, #7C3AED);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }

  /* ── SECTIONS ─────────────────────────────────────── */
  .r-section { padding: 3rem 1.5rem; }
  .r-two-col {
    max-width: 1060px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
    align-items: start;
  }
  @media (max-width: 700px) { .r-two-col { grid-template-columns: 1fr; } }

  /* ── CARDS ────────────────────────────────────────── */
  .r-card { padding: 1.75rem; }
  .r-card-label {
    font-family: 'Space Grotesk', sans-serif; font-size: 0.68rem;
    font-weight: 700; letter-spacing: 0.1em; color: var(--cyan);
    text-transform: uppercase; margin-bottom: 1.25rem;
  }
  .r-right-col { display: flex; flex-direction: column; gap: 1.5rem; }

  /* Radar */
  .radar-wrap { margin: 0 auto 1.5rem; max-width: 260px; }

  /* Dim bars */
  .dim-bars { display: flex; flex-direction: column; gap: 0.85rem; }
  .dim-bar-row { display: flex; align-items: center; gap: 0.75rem; }
  .dbr-label {
    font-family: 'Space Grotesk', sans-serif; font-size: 0.8rem;
    font-weight: 600; color: var(--muted); width: 38px;
  }
  .dbr-track {
    flex: 1; height: 6px; background: rgba(0,207,255,0.1);
    border-radius: 999px; overflow: hidden;
  }
  .dbr-fill {
    height: 100%; border-radius: 999px; width: 0%;
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .dbr-think { background: linear-gradient(90deg, #00CFFF, #7C3AED); }
  .dbr-apply { background: linear-gradient(90deg, #7C3AED, #a855f7); }
  .dbr-lead  { background: linear-gradient(90deg, #00CFFF 0%, #7C3AED 100%); opacity: 0.75; }
  .dbr-val {
    font-family: 'JetBrains Mono', monospace; font-size: 0.82rem;
    color: var(--muted); width: 32px; text-align: right;
  }

  /* Insight */
  .insight-text {
    font-size: 1rem; line-height: 1.7; color: var(--text);
  }

  /* Course rec */
  .course-rec { }
  .cr-track { font-family: 'Space Grotesk', sans-serif; font-size: 1.1rem; font-weight: 700; margin-bottom: 0.4rem; }
  .cr-track span { background: linear-gradient(135deg,#00CFFF,#7C3AED); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
  .cr-meta { font-size: 0.85rem; color: var(--muted); margin-bottom: 1.25rem; }
  .cr-link { font-size: 0.9rem; }

  /* Share */
  .r-share-section { padding: 2rem 1.5rem; }
  .share-inner {
    max-width: 700px; margin: 0 auto;
    display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;
  }
  .share-label {
    font-family: 'Space Grotesk', sans-serif; font-size: 0.9rem;
    font-weight: 600; color: var(--muted);
  }
  .share-btns { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .share-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.6rem 1.2rem; border-radius: 999px; border: 1px solid;
    font-family: 'Space Grotesk', sans-serif; font-size: 0.85rem; font-weight: 600;
    cursor: pointer; transition: all 0.2s;
  }
  .share-li  { border-color: rgba(0,119,181,0.5); color: #0077B5; background: rgba(0,119,181,0.06); }
  .share-li:hover { background: rgba(0,119,181,0.12); }
  .share-x   { border-color: rgba(232,240,255,0.2); color: var(--text); background: rgba(255,255,255,0.04); }
  .share-x:hover { background: rgba(255,255,255,0.08); }
  .share-copy { border-color: rgba(0,207,255,0.25); color: var(--cyan); background: rgba(0,207,255,0.06); }
  .share-copy:hover { background: rgba(0,207,255,0.12); }

  /* ── TIER IDENTITY CARD ──────────────────────────── */
  .r-tier-id-section { padding: 0 1.5rem 2rem; }
  .tier-id-card {
    position: relative;
    max-width: 600px;
    margin: 0 auto;
    border-radius: 20px;
    border: 1px solid rgba(0,207,255,0.25);
    background: rgba(8,13,26,0.9);
    overflow: hidden;
    padding: 2rem 2.5rem;
  }
  .tier-id-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 500px 300px at 80% 50%, rgba(124,58,237,0.12) 0%, transparent 70%),
                radial-gradient(ellipse 300px 200px at 10% 20%, rgba(0,207,255,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .tier-id-inner { position: relative; z-index: 1; }
  .tier-id-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.75rem;
  }
  .tier-id-brand {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--cyan);
    text-transform: uppercase;
  }
  .tier-id-score-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    color: var(--muted);
  }
  .tier-id-score-val {
    color: var(--text);
    font-weight: 700;
  }
  .tier-id-main {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
    border-top: 1px solid rgba(0,207,255,0.12);
    border-bottom: 1px solid rgba(0,207,255,0.12);
    padding: 1.25rem 0;
  }
  .tier-id-you {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .tier-id-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.5rem, 8vw, 3.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .tier-id-dims {
    display: flex;
    gap: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .tid-dim-val { color: var(--text); font-weight: 700; }
  .tid-sep { opacity: 0.4; }
  .tier-id-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .tier-id-url {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: rgba(107,122,153,0.6);
  }
  .tier-id-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: rgba(0,207,255,0.5);
    text-transform: uppercase;
  }
  .tier-id-hint {
    text-align: center;
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: 0.85rem;
    opacity: 0.7;
  }

  /* ── RETAKE BAND ──────────────────────────────────── */
  .r-retake-section { padding: 0 1.5rem 3rem; }
  .retake-band {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 1.75rem;
    flex-wrap: wrap;
  }
  .retake-icon { flex-shrink: 0; }
  .retake-text {
    flex: 1;
    min-width: 200px;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .retake-text strong {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
  }
  .retake-text span {
    font-size: 0.85rem;
    color: var(--muted);
  }
  .retake-cta {
    font-size: 0.85rem;
    padding: 0.6rem 1.5rem;
    white-space: nowrap;
  }

  /* CTA section */
  .r-cta-section { padding: 3rem 1.5rem 6rem; }
  .r-cta-card {
    max-width: 760px; margin: 0 auto; padding: 3rem;
    text-align: center; position: relative; overflow: hidden;
  }
  .cta-h2 {
    font-family: 'Space Grotesk', sans-serif; font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    font-weight: 800; margin-bottom: 1rem;
  }
  .cta-sub { color: var(--muted); font-size: 1rem; line-height: 1.7; margin-bottom: 2rem; }
  .cta-features {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem 1.5rem;
    max-width: 480px; margin: 0 auto 2.5rem; text-align: left;
  }
  @media (max-width: 480px) { .cta-features { grid-template-columns: 1fr; } }
  .cta-feat { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.9rem; color: var(--muted); }
  .feat-icon { color: var(--cyan); font-weight: 700; flex-shrink: 0; }
  .cta-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-lg { padding: 1rem 2.5rem; font-size: 1rem; }
</style>

<script>
(function () {
  const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
  const SOCIETY_URL = 'https://walnut-sea-abb.notion.site/3213f9fc4e588013bacbe0f823a2ae09?pvs=105';

  // Wire up retake / take links
  document.getElementById('btn-retake').href = BASE + '/assessment';
  document.getElementById('btn-take') && (document.getElementById('btn-take').href = BASE + '/assessment');
  document.getElementById('btn-join-society').href = SOCIETY_URL;

  // ── Load result from localStorage ────────────────────
  let result;
  try {
    result = JSON.parse(localStorage.getItem('aiq_latest_result'));
  } catch (_) { result = null; }

  if (!result) {
    document.getElementById('no-result').style.display = 'block';
    return;
  }

  document.getElementById('results-content').style.display = 'block';

  const { scores, tier, insight } = result;

  // ── Score ring animation ──────────────────────────────
  const CIRCUMFERENCE = 515;
  const arc = document.getElementById('score-arc');
  const numEl = document.getElementById('score-number');

  function animateScore(target, duration) {
    const start = performance.now();
    function update(now) {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(eased * target);
      numEl.textContent = current;
      arc.style.strokeDashoffset = CIRCUMFERENCE - (eased * (CIRCUMFERENCE * target / 100));
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  }

  setTimeout(() => animateScore(scores.aiq, 2000), 300);

  // ── Tier / score text ─────────────────────────────────
  document.getElementById('tier-num').textContent = tier.tier;
  document.getElementById('tier-label').textContent = tier.label;
  document.getElementById('tier-desc').textContent = tier.desc;
  document.getElementById('score-think').textContent = scores.think;
  document.getElementById('score-apply').textContent = scores.apply;
  document.getElementById('score-lead').textContent = scores.lead;

  // Populate tier identity card
  const tidScore = document.getElementById('tid-score');
  const tidLabel = document.getElementById('tid-label');
  const tidThink = document.getElementById('tid-think');
  const tidApply = document.getElementById('tid-apply');
  const tidLead  = document.getElementById('tid-lead');
  if (tidScore) tidScore.textContent = result.scores.aiq;
  if (tidLabel) tidLabel.textContent = result.tier.label;
  if (tidThink) tidThink.textContent = result.scores.think;
  if (tidApply) tidApply.textContent = result.scores.apply;
  if (tidLead)  tidLead.textContent  = result.scores.lead;

  // Wire retake band button
  const retakeBandBtn = document.getElementById('btn-retake-band');
  if (retakeBandBtn) retakeBandBtn.href = BASE + '/assessment';

  // ── Dim bar fills ─────────────────────────────────────
  setTimeout(() => {
    document.getElementById('bar-think').style.width = scores.think + '%';
    document.getElementById('bar-apply').style.width = scores.apply + '%';
    document.getElementById('bar-lead').style.width  = scores.lead  + '%';
    document.getElementById('dbr-think-val').textContent = scores.think;
    document.getElementById('dbr-apply-val').textContent = scores.apply;
    document.getElementById('dbr-lead-val').textContent  = scores.lead;
  }, 400);

  // ── Insight ───────────────────────────────────────────
  document.getElementById('insight-text').textContent = insight;

  // ── Course recommendation ─────────────────────────────
  const TRACKS = {
    foundations: {
      name: 'AI~Foundations',
      meta: '6 hrs · 12 modules · Tiers 0–3',
      path: '/courses/foundations',
    },
    workflows: {
      name: 'AI~Workflows',
      meta: '10 hrs · 20 modules · Tiers 3–6',
      path: '/courses/workflows',
    },
    leadership: {
      name: 'AI~Leadership',
      meta: '8 hrs · 16 modules · Tiers 6–8',
      path: '/courses/leadership',
    },
  };

  const track = TRACKS[tier.track] || TRACKS.foundations;
  document.getElementById('btn-view-course').href = BASE + track.path;
  document.getElementById('course-rec').innerHTML = `
    <div class="cr-track"><span>${track.name}</span></div>
    <div class="cr-meta">${track.meta}</div>
    <a class="btn-secondary cr-link" href="${BASE + track.path}">View Course →</a>
  `;

  // ── Radar chart ───────────────────────────────────────
  function initChart() {
    const canvas = document.getElementById('radar-chart');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');

    new window.Chart(ctx, {
      type: 'radar',
      data: {
        labels: ['Think (35%)', 'Apply (45%)', 'Lead (20%)'],
        datasets: [{
          data: [scores.think, scores.apply, scores.lead],
          backgroundColor: 'rgba(0, 207, 255, 0.08)',
          borderColor: '#00CFFF',
          borderWidth: 2,
          pointBackgroundColor: '#00CFFF',
          pointBorderColor: '#7C3AED',
          pointRadius: 4,
          pointHoverRadius: 6,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: { legend: { display: false } },
        scales: {
          r: {
            min: 0,
            max: 100,
            ticks: { display: false, stepSize: 25 },
            grid: { color: 'rgba(0, 207, 255, 0.12)' },
            angleLines: { color: 'rgba(0, 207, 255, 0.15)' },
            pointLabels: {
              font: { family: 'Space Grotesk', size: 12, weight: '600' },
              color: '#E8F0FF',
            },
          },
        },
      },
    });
  }

  function loadChartJS() {
    if (window.Chart) { initChart(); return; }
    const s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js';
    s.onload = initChart;
    document.head.appendChild(s);
  }

  setTimeout(loadChartJS, 500);

  // ── Share ─────────────────────────────────────────────
  const shareUrl = 'https://rambjorgrd2.github.io/AIQ/assessment';
  const linkedInShareText = `I just discovered my AI~Quotient. I'm a ${tier.label} — AIQ score: ${scores.aiq}. Know before you Grow. Discover yours: ${shareUrl}`;

  document.getElementById('share-linkedin').addEventListener('click', () => {
    const liUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}&summary=${encodeURIComponent(linkedInShareText)}`;
    window.open(liUrl, '_blank');
  });

  document.getElementById('share-x').addEventListener('click', () => {
    const text = `My AIQ: ${scores.aiq} — ${tier.label} 🧠\nThink: ${scores.think} · Apply: ${scores.apply} · Lead: ${scores.lead}\n\nFind your AI Quotient:`;
    window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(shareUrl)}`, '_blank');
  });

  document.getElementById('share-copy').addEventListener('click', async () => {
    const copyText = `My AIQ Score: ${scores.aiq} — ${tier.label} (Tier ${tier.tier})\nThink: ${scores.think} · Apply: ${scores.apply} · Lead: ${scores.lead}\nKnow Your AIQ: ${shareUrl}`;
    try {
      await navigator.clipboard.writeText(copyText);
      const label = document.getElementById('copy-label');
      label.textContent = 'Copied!';
      setTimeout(() => { label.textContent = 'Copy Score'; }, 2500);
    } catch (_) {}
  });

})();
</script>

</Layout>
