---
import Layout from '../layouts/Layout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Host a Session — Sosial AI Forum"
  description="Share your AI expertise with the Sosial AI community. Propose a workshop, webinar, roundtable, or brAInstorm session. We review every application."
>

<SiteNav />

<!-- HERO -->
<section class="sp-hero grid-bg">
  <div class="glow-blob" style="width:500px;height:500px;background:var(--violet);top:-180px;right:-180px;"></div>
  <div class="glow-blob" style="width:350px;height:350px;background:var(--cyan);bottom:-80px;left:-100px;"></div>
  <div class="container sp-hero-inner">
    <div class="chip reveal">Sosial AI Forum</div>
    <h1 class="sp-hero-h1 reveal reveal-delay-1">Share what you know.</h1>
    <p class="sp-hero-sub reveal reveal-delay-2">
      The Sosial AI Forum is built around practitioners, not presenters. If you're doing real AI work — in any role, at any tier — we want to hear from you. Propose a session below.
    </p>
    <div class="sp-hero-pills reveal reveal-delay-3">
      <span class="sp-pill">🛠️ Workshop</span>
      <span class="sp-pill">📡 Webinar</span>
      <span class="sp-pill">🔵 Roundtable</span>
      <span class="sp-pill">⚡ brAInstorm</span>
    </div>
  </div>
</section>

<!-- WHAT WE'RE LOOKING FOR -->
<section class="sp-section">
  <div class="container">
    <div class="sp-section-head reveal">
      <div class="chip">What makes a good session</div>
      <h2 class="section-title">Practical over polished.</h2>
      <p class="section-sub">We're not looking for keynotes. We're looking for sessions that move people forward.</p>
    </div>
    <div class="sp-pillars">
      {[
        { icon: '⚙️', title: 'Show the work', desc: 'Real prompts, real outputs, real systems. Sessions that let participants try something themselves beat slide decks every time.' },
        { icon: '🎯', title: 'Tier-aware content', desc: 'Know your audience. Is your session for people new to AI (Tiers 0–3), practitioners building systems (Tiers 3–6), or leaders driving strategy (Tiers 6–8)?' },
        { icon: '🌐', title: 'Any domain, any role', desc: 'AI in healthcare, law, education, design, engineering, operations — all welcome. The more specific your niche, the more valuable your session.' },
      ].map(p => (
        <div class="sp-pillar glass reveal">
          <div class="sp-pillar-icon">{p.icon}</div>
          <h3 class="sp-pillar-title">{p.title}</h3>
          <p class="sp-pillar-desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- APPLICATION FORM -->
<section class="sp-section sp-form-section">
  <div class="container">
    <div class="sp-form-wrap">

      <!-- Loading state -->
      <div id="sp-loading" class="sp-state-card glass">
        <div class="sp-spinner"></div>
        <p class="sp-state-sub">Checking application status…</p>
      </div>

      <!-- Closed state -->
      <div id="sp-closed" class="sp-state-card glass" style="display:none">
        <div class="sp-state-icon">🔒</div>
        <h2 class="sp-state-title">Applications are currently closed</h2>
        <p class="sp-state-sub">We're not accepting new speaker proposals right now — but we will be again soon. Join the Society to hear when the next application window opens.</p>
        <a href={`${base}/forum`} class="btn-secondary" style="margin-top:1.5rem">Back to the Forum →</a>
      </div>

      <!-- Success state -->
      <div id="sp-success" class="sp-state-card glass" style="display:none">
        <div class="sp-state-icon">✅</div>
        <h2 class="sp-state-title">Application received.</h2>
        <p class="sp-state-sub">Thanks for proposing a session. We review every application personally and will be in touch within 5 business days. Keep doing great work in the meantime.</p>
        <div class="sp-success-actions">
          <a href={`${base}/forum`} class="btn-primary">See upcoming events →</a>
          <a href={`${base}/society`} class="btn-secondary">Join the Society</a>
        </div>
      </div>

      <!-- Application form -->
      <form id="sp-form" class="sp-form glass" style="display:none" novalidate>
        <div class="sp-form-header">
          <div class="chip" style="margin-bottom:1rem">Speaker Application</div>
          <h2 class="sp-form-title">Propose a session</h2>
          <p class="sp-form-sub">All fields required unless marked optional. We read every application.</p>
        </div>

        <!-- Section: Your session -->
        <fieldset class="sp-fieldset">
          <legend class="sp-legend">Your session</legend>

          <div class="sp-field">
            <label class="sp-label" for="sp-session-type">Session format</label>
            <select id="sp-session-type" name="sessionType" class="sp-select" required>
              <option value="" disabled selected>Choose a format…</option>
              <option value="Workshop">Workshop — hands-on, ≤30 people</option>
              <option value="Webinar">Webinar — structured deep dive, larger audience</option>
              <option value="Roundtable">Roundtable — facilitated peer discussion</option>
              <option value="Q&A">Q&A — open questions around your area of expertise</option>
              <option value="brAInstorm">brAInstorm — our flagship open-exploration format</option>
            </select>
          </div>

          <div class="sp-field">
            <label class="sp-label" for="sp-topic-title">
              Session title
              <span class="sp-label-hint">Make it specific — e.g. "How I automated client reporting with Claude" not "AI for business"</span>
            </label>
            <input
              id="sp-topic-title"
              name="topicTitle"
              type="text"
              class="sp-input"
              placeholder="What's your session called?"
              maxlength="120"
              required
            />
          </div>

          <div class="sp-field">
            <label class="sp-label" for="sp-abstract">
              What will participants learn or do?
              <span class="sp-label-hint">Describe the content, format, and what someone walks away with. 100–500 characters.</span>
            </label>
            <textarea
              id="sp-abstract"
              name="abstract"
              class="sp-textarea"
              placeholder="Give us a clear picture of what the session covers and how it's structured…"
              rows="4"
              minlength="100"
              maxlength="500"
              required
            ></textarea>
            <div class="sp-char-counter"><span id="sp-abstract-count">0</span> / 500</div>
          </div>

          <div class="sp-field">
            <label class="sp-label" for="sp-tier">
              Who is this for?
            </label>
            <select id="sp-tier" name="tier" class="sp-select" required>
              <option value="" disabled selected>Select an audience tier…</option>
              <option value="Tiers 0–3 (AI Foundations)">Tiers 0–3 — new to AI, building foundations</option>
              <option value="Tiers 3–6 (AI Workflows)">Tiers 3–6 — practitioner building systems</option>
              <option value="Tiers 6–8 (AI Leadership)">Tiers 6–8 — leadership and strategy</option>
              <option value="All tiers">All tiers — accessible to everyone</option>
            </select>
          </div>
        </fieldset>

        <!-- Section: About you -->
        <fieldset class="sp-fieldset">
          <legend class="sp-legend">About you</legend>

          <div class="sp-field-row">
            <div class="sp-field">
              <label class="sp-label" for="sp-name">Your name</label>
              <input id="sp-name" name="name" type="text" class="sp-input" placeholder="Full name" required />
            </div>
            <div class="sp-field">
              <label class="sp-label" for="sp-email">Email address</label>
              <input id="sp-email" name="email" type="email" class="sp-input" placeholder="you@example.com" required />
            </div>
          </div>

          <div class="sp-field">
            <label class="sp-label" for="sp-bio">
              Brief bio
              <span class="sp-label-hint">Who are you and why are you the right person to run this session? 50–300 characters.</span>
            </label>
            <textarea
              id="sp-bio"
              name="bio"
              class="sp-textarea"
              placeholder="Role, domain, relevant experience — keep it short and honest…"
              rows="3"
              minlength="50"
              maxlength="300"
              required
            ></textarea>
            <div class="sp-char-counter"><span id="sp-bio-count">0</span> / 300</div>
          </div>

          <div class="sp-field">
            <label class="sp-label" for="sp-links">
              LinkedIn, website, or relevant links
              <span class="sp-label-hint">Optional — helps us understand your background and previous work.</span>
            </label>
            <input
              id="sp-links"
              name="links"
              type="text"
              class="sp-input"
              placeholder="https://linkedin.com/in/… or your website"
            />
          </div>
        </fieldset>

        <!-- Section: Scheduling -->
        <fieldset class="sp-fieldset">
          <legend class="sp-legend">Scheduling preference</legend>

          <div class="sp-field">
            <label class="sp-label" for="sp-month">
              Preferred timeframe
              <span class="sp-label-hint">We'll do our best — not a guarantee. "Flexible" is fine.</span>
            </label>
            <select id="sp-month" name="preferredMonth" class="sp-select" required>
              <option value="" disabled selected>Select a timeframe…</option>
              <option value="Flexible">Flexible — any time works</option>
              <!-- Options populated dynamically by JS -->
            </select>
          </div>
        </fieldset>

        <!-- Error message -->
        <div id="sp-error" class="sp-error-msg" style="display:none" role="alert">
          Something went wrong submitting your application. Please try again or email us directly.
        </div>

        <!-- Submit -->
        <div class="sp-form-footer">
          <p class="sp-form-note">By submitting you agree to us contacting you about your application. We don't share your details with third parties.</p>
          <button type="submit" class="btn-primary sp-submit-btn" id="sp-submit">
            <span id="sp-submit-label">Submit application</span>
            <span id="sp-submit-spinner" class="sp-btn-spinner" style="display:none"></span>
            <svg id="sp-submit-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </form>

    </div>
  </div>
</section>

<!-- WHAT HAPPENS NEXT -->
<section class="sp-section sp-next-section">
  <div class="container">
    <div class="sp-section-head reveal">
      <div class="chip">Process</div>
      <h2 class="section-title">What happens after you apply.</h2>
    </div>
    <div class="sp-steps">
      {[
        { n: '01', title: 'We review your proposal', desc: 'Every application is read by a human. We look for practical content, clear audience fit, and genuine expertise. You\'ll hear back within 5 business days.' },
        { n: '02', title: 'We confirm the details', desc: 'If we want to move forward, we\'ll reach out to align on date, format, audience size, and any logistics. No commitment until both sides agree.' },
        { n: '03', title: 'Your session goes live', desc: 'We create the event on Luma, list it on the Forum calendar, and promote it to the community. You focus on running a great session.' },
      ].map((s, i) => (
        <div class={`sp-step glass reveal${i > 0 ? ` reveal-delay-${i}` : ''}`}>
          <div class="sp-step-n">{s.n}</div>
          <div class="sp-step-body">
            <h3 class="sp-step-title">{s.title}</h3>
            <p class="sp-step-desc">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<SiteFooter />
</Layout>

<style>
  .sp-hero {
    padding: 7rem 1.5rem 5rem;
    position: relative;
    overflow: hidden;
    text-align: center;
  }
  .sp-hero-inner { max-width: 680px; margin: 0 auto; }
  .sp-hero-h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    background: linear-gradient(135deg, #E8F0FF, #00CFFF);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    margin: 1rem 0 1.25rem;
  }
  .sp-hero-sub { color: var(--muted); font-size: 1.05rem; line-height: 1.75; margin-bottom: 2rem; }
  .sp-hero-pills { display: flex; gap: 0.6rem; justify-content: center; flex-wrap: wrap; }
  .sp-pill {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.82rem; font-weight: 600;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    background: rgba(0,207,255,0.07);
    border: 1px solid rgba(0,207,255,0.2);
    color: var(--cyan);
  }

  .sp-section { padding: 5rem 1.5rem; }
  .sp-section-head { margin-bottom: 3rem; }
  .sp-form-section { background: rgba(8,13,26,0.5); padding: 4rem 1.5rem 5rem; }

  /* PILLARS */
  .sp-pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .sp-pillar { padding: 1.75rem; }
  .sp-pillar-icon { font-size: 1.75rem; margin-bottom: 0.85rem; }
  .sp-pillar-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.05rem; font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .sp-pillar-desc { color: var(--muted); font-size: 0.9rem; line-height: 1.65; }

  /* FORM WRAP */
  .sp-form-wrap { max-width: 720px; margin: 0 auto; }

  /* STATE CARDS */
  .sp-state-card {
    padding: 3rem 2rem;
    text-align: center;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .sp-state-icon { font-size: 2.5rem; }
  .sp-state-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.5rem; font-weight: 800;
    color: var(--text);
  }
  .sp-state-sub { color: var(--muted); font-size: 0.95rem; line-height: 1.7; max-width: 480px; }
  .sp-success-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; justify-content: center; margin-top: 0.5rem; }

  /* SPINNER (loading state) */
  .sp-spinner {
    width: 32px; height: 32px;
    border: 2px solid rgba(0,207,255,0.15);
    border-top-color: var(--cyan);
    border-radius: 50%;
    animation: sp-spin 0.7s linear infinite;
  }
  @keyframes sp-spin { to { transform: rotate(360deg); } }

  /* FORM */
  .sp-form {
    padding: 2.5rem;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .sp-form-header { }
  .sp-form-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.5rem; font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .sp-form-sub { color: var(--muted); font-size: 0.9rem; }

  .sp-fieldset {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .sp-legend {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 0.75rem;
    padding: 0;
  }
  .sp-field { display: flex; flex-direction: column; gap: 0.4rem; }
  .sp-field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 560px) { .sp-field-row { grid-template-columns: 1fr; } }

  .sp-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.88rem; font-weight: 600;
    color: var(--text);
    display: flex; flex-direction: column; gap: 0.2rem;
  }
  .sp-label-hint {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem; font-weight: 400;
    color: var(--muted);
  }

  .sp-input, .sp-select, .sp-textarea {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 0.92rem;
    padding: 0.7rem 0.9rem;
    width: 100%;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    box-sizing: border-box;
  }
  .sp-input::placeholder, .sp-textarea::placeholder { color: rgba(107,122,153,0.6); }
  .sp-select option { background: #0d1221; color: var(--text); }
  .sp-textarea { resize: vertical; min-height: 90px; }

  .sp-input:focus, .sp-select:focus, .sp-textarea:focus {
    border-color: rgba(0,207,255,0.45);
    box-shadow: 0 0 0 3px rgba(0,207,255,0.08);
  }
  .sp-input.sp-invalid, .sp-select.sp-invalid, .sp-textarea.sp-invalid {
    border-color: rgba(239,68,68,0.5);
  }

  .sp-char-counter {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: var(--muted);
    text-align: right;
    margin-top: 0.2rem;
  }

  .sp-error-msg {
    background: rgba(239,68,68,0.08);
    border: 1px solid rgba(239,68,68,0.25);
    border-radius: 8px;
    color: #fca5a5;
    font-size: 0.88rem;
    padding: 0.75rem 1rem;
  }

  .sp-form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .sp-form-note { color: var(--muted); font-size: 0.78rem; line-height: 1.5; flex: 1; min-width: 200px; }
  .sp-submit-btn {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.85rem 2rem; font-size: 0.95rem;
    flex-shrink: 0; position: relative;
  }
  .sp-submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .sp-btn-spinner {
    width: 16px; height: 16px;
    border: 2px solid rgba(255,255,255,0.25);
    border-top-color: white;
    border-radius: 50%;
    animation: sp-spin 0.6s linear infinite;
  }

  /* STEPS */
  .sp-next-section { padding-bottom: 7rem; }
  .sp-steps { display: flex; flex-direction: column; gap: 1rem; max-width: 680px; margin: 0 auto; }
  .sp-step {
    display: flex; align-items: flex-start; gap: 1.5rem;
    padding: 1.5rem 1.75rem;
  }
  .sp-step-n {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.25rem; font-weight: 700;
    color: var(--cyan); opacity: 0.5;
    flex-shrink: 0; line-height: 1.4;
  }
  .sp-step-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem; font-weight: 700;
    margin-bottom: 0.35rem;
  }
  .sp-step-desc { color: var(--muted); font-size: 0.88rem; line-height: 1.65; }
</style>

<script>
  import { supabase } from '../lib/supabase.ts';
  import { submitSpeakerApplication, isSpeakerApplicationsOpen } from '../lib/db.ts';

  const loadingEl  = document.getElementById('sp-loading')!;
  const closedEl   = document.getElementById('sp-closed')!;
  const successEl  = document.getElementById('sp-success')!;
  const formEl     = document.getElementById('sp-form') as HTMLFormElement;
  const errorEl    = document.getElementById('sp-error')!;
  const submitBtn  = document.getElementById('sp-submit') as HTMLButtonElement;
  const submitLabel  = document.getElementById('sp-submit-label')!;
  const submitSpinner = document.getElementById('sp-submit-spinner')!;
  const submitArrow   = document.getElementById('sp-submit-arrow')!;

  // ── Populate month options ──────────────────────────────────────────────────
  const monthSelect = document.getElementById('sp-month') as HTMLSelectElement;
  const now = new Date();
  for (let i = 0; i < 6; i++) {
    const d = new Date(now.getFullYear(), now.getMonth() + i + 1, 1);
    const label = d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
    const opt = document.createElement('option');
    opt.value = label;
    opt.textContent = label;
    monthSelect.appendChild(opt);
  }

  // ── Character counters ──────────────────────────────────────────────────────
  function attachCounter(textareaId: string, counterId: string) {
    const ta = document.getElementById(textareaId) as HTMLTextAreaElement;
    const counter = document.getElementById(counterId)!;
    ta?.addEventListener('input', () => { counter.textContent = String(ta.value.length); });
  }
  attachCounter('sp-abstract', 'sp-abstract-count');
  attachCounter('sp-bio', 'sp-bio-count');

  // ── Check toggle and show correct state ────────────────────────────────────
  function show(el: HTMLElement) { el.style.display = ''; }
  function hide(el: HTMLElement) { el.style.display = 'none'; }

  async function init() {
    try {
      const isOpen = await isSpeakerApplicationsOpen();
      hide(loadingEl);
      if (isOpen) {
        show(formEl);
      } else {
        show(closedEl);
      }
    } catch (_e) {
      // On error default to showing the form
      hide(loadingEl);
      show(formEl);
    }
  }
  init();

  // ── Scroll reveal ───────────────────────────────────────────────────────────
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  // ── Form submission ─────────────────────────────────────────────────────────
  function setLoading(loading: boolean) {
    submitBtn.disabled = loading;
    submitLabel.textContent = loading ? 'Submitting…' : 'Submit application';
    submitSpinner.style.display = loading ? '' : 'none';
    submitArrow.style.display = loading ? 'none' : '';
  }

  function markInvalid(field: HTMLElement) {
    field.classList.add('sp-invalid');
    field.addEventListener('input', () => field.classList.remove('sp-invalid'), { once: true });
  }

  formEl?.addEventListener('submit', async (e) => {
    e.preventDefault();
    hide(errorEl);

    const get = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement).value.trim();

    const sessionType   = get('sp-session-type');
    const topicTitle    = get('sp-topic-title');
    const abstract      = get('sp-abstract');
    const tier          = get('sp-tier');
    const name          = get('sp-name');
    const email         = get('sp-email');
    const bio           = get('sp-bio');
    const links         = get('sp-links');
    const preferredMonth = get('sp-month');

    // Basic validation
    let valid = true;
    const required: [string, string][] = [
      ['sp-session-type', sessionType],
      ['sp-topic-title', topicTitle],
      ['sp-abstract', abstract],
      ['sp-tier', tier],
      ['sp-name', name],
      ['sp-email', email],
      ['sp-bio', bio],
      ['sp-month', preferredMonth],
    ];
    for (const [id, val] of required) {
      if (!val) {
        markInvalid(document.getElementById(id)!);
        valid = false;
      }
    }
    if (abstract.length < 100) { markInvalid(document.getElementById('sp-abstract')!); valid = false; }
    if (bio.length < 50) { markInvalid(document.getElementById('sp-bio')!); valid = false; }
    if (!email.includes('@')) { markInvalid(document.getElementById('sp-email')!); valid = false; }
    if (!valid) return;

    setLoading(true);
    try {
      await submitSpeakerApplication({
        name,
        email,
        topicTitle,
        sessionType,
        abstract: `[${tier}] ${abstract}`,
        bio,
        preferredMonth,
        links: links || undefined,
      });
      hide(formEl);
      show(successEl);
      window.scrollTo({ top: document.getElementById('sp-success')!.offsetTop - 100, behavior: 'smooth' });
    } catch (_err) {
      show(errorEl);
      setLoading(false);
    }
  });
</script>
